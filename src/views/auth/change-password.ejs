<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Cambia password' }) %>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container-sm">
    <div class="card">
      <h1 style="margin-bottom:8px;">Cambia password</h1>
      <p style="color:#64748b; margin-bottom:24px; font-size:.9rem;">
        È il tuo primo accesso. Devi impostare una nuova password prima di continuare.
      </p>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <div class="alert alert-info" style="margin-bottom:20px;">
        La password deve contenere almeno <strong>8 caratteri</strong>.
      </div>

      <form action="/auth/change-password" method="POST">
        <div class="form-group">
          <label for="password">Nuova password</label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="Almeno 8 caratteri"
            required
            minlength="8"
            autofocus
          />
        </div>
        <div class="form-group">
          <label for="confirmPassword">Conferma password</label>
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            placeholder="Ripeti la nuova password"
            required
            minlength="8"
          />
        </div>
        <button type="submit" class="btn btn-primary btn-block" style="margin-top:8px;">
          Imposta password
        </button>
      </form>
    </div>
  </div>
</body>
</html>
