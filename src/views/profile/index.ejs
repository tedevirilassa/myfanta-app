<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Il mio profilo' }) %>
  <style>
    .profile-avatar {
      width: 72px; height: 72px; border-radius: 50%;
      background: var(--green-mid);
      display: flex; align-items: center; justify-content: center;
      font-size: 2rem; font-weight: 900; color: #fff;
      margin-bottom: 16px;
    }
    .form-group { margin-bottom: 18px; }
    .form-label {
      display: block; font-size: .82rem; font-weight: 700;
      color: var(--gray-600); margin-bottom: 6px;
      text-transform: uppercase; letter-spacing: .4px;
    }
    .form-input {
      width: 100%; padding: 10px 14px;
      border: 1px solid var(--gray-200); border-radius: 8px;
      font-size: .95rem; outline: none;
      transition: border-color .15s, box-shadow .15s;
    }
    .form-input:focus {
      border-color: var(--green-mid);
      box-shadow: 0 0 0 3px rgba(45,106,79,.15);
    }
    .form-hint { font-size: .75rem; color: var(--gray-400); margin-top: 4px; }
    .badge-info {
      display: inline-block; padding: 2px 10px; border-radius: 12px;
      font-size: .72rem; font-weight: 700; text-transform: uppercase;
    }
    .bi-admin { background: #fef3c7; color: #92400e; }
    .bi-user  { background: #e0e7ff; color: #3730a3; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container" style="max-width: 560px;">
    <div class="page-header">
      <h1>👤 Il mio profilo</h1>
    </div>

    <% if (success) { %>
    <div class="alert alert-success" style="margin-bottom: 20px;"><%= success %></div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-error" style="margin-bottom: 20px;"><%= error %></div>
    <% } %>

    <!-- scheda identità (sola lettura) -->
    <div class="card" style="padding: 24px; margin-bottom: 24px; text-align: center;">
      <div style="display: flex; justify-content: center;">
        <div class="profile-avatar">
          <%= (currentUser.nickname || currentUser.email).charAt(0).toUpperCase() %>
        </div>
      </div>
      <div style="font-size: 1.1rem; font-weight: 900; color: var(--green-dark); margin-bottom: 4px;">
        <%= currentUser.nickname || currentUser.email %>
      </div>
      <% if (currentUser.fantaTeam && currentUser.fantaTeam.nome) { %>
      <div style="font-size: .9rem; color: var(--gray-500); margin-bottom: 10px;">
        🏟️ <em><%= currentUser.fantaTeam.nome %></em>
      </div>
      <% } %>
      <div>
        <span class="badge-info <%= currentUser.role === 'ADMIN' ? 'bi-admin' : 'bi-user' %>">
          <%= currentUser.role %>
        </span>
        &nbsp;
        <span style="font-size: .8rem; color: var(--gray-400);"><%= currentUser.email %></span>
      </div>
    </div>

    <!-- form modifica -->
    <div class="card" style="padding: 28px;">
      <h2 style="font-size: 1rem; margin-bottom: 20px; color: var(--green-dark);">✏️ Modifica profilo</h2>
      <form method="POST" action="/profilo">
        <div class="form-group">
          <label class="form-label" for="nickname">Nickname</label>
          <input
            class="form-input"
            type="text"
            id="nickname"
            name="nickname"
            maxlength="40"
            placeholder="Es. Il Condor"
            value="<%= currentUser.nickname || '' %>"
          >
          <div class="form-hint">Max 40 caratteri. Viene mostrato in classifica e profilo.</div>
        </div>

        <div class="form-group">
          <label class="form-label" for="teamName">Nome squadra</label>
          <input
            class="form-input"
            type="text"
            id="teamName"
            name="teamName"
            maxlength="60"
            placeholder="Es. Aquile del Nord FC"
            value="<%= (currentUser.fantaTeam && currentUser.fantaTeam.nome) || '' %>"
          >
          <div class="form-hint">Max 60 caratteri. Il nome della tua rosa.</div>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 11px;">
          💾 Salva modifiche
        </button>
      </form>
    </div>

    <!-- link cambio password -->
    <div style="text-align: center; margin-top: 16px;">
      <a href="/auth/change-password" style="font-size: .85rem; color: var(--green-mid); text-decoration: none;">
        🔑 Cambia password
      </a>
    </div>
  </div>
</body>
</html>
