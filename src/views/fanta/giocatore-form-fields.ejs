<%/* partial: campi form giocatore – usato da modal aggiungi e modifica */%>
<div class="form-group">
  <label>Nome *</label>
  <input type="text" name="nome" value="<%= g ? g.nome : '' %>" required placeholder="es. Marco Rossi" />
</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
  <div class="form-group">
    <label>Ruolo *</label>
    <select name="ruolo" required>
      <option value="">—</option>
      <% ['P','D','C','A'].forEach(function(r) { %>
        <option value="<%= r %>" <%= g && g.ruolo === r ? 'selected' : '' %>><%= r %></option>
      <% }) %>
    </select>
  </div>
  <div class="form-group">
    <label>Ruolo Esteso</label>
    <input type="text" name="ruoloEsteso" value="<%= g ? (g.ruoloEsteso || '') : '' %>" placeholder="es. Trequartista" />
  </div>
</div>
<div class="form-group">
  <label>Squadra</label>
  <input type="text" name="squadra" value="<%= g ? (g.squadra || '') : '' %>" placeholder="es. Inter" />
</div>
<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
  <div class="form-group">
    <label>Età</label>
    <input type="number" name="eta" value="<%= g && g.eta !== null ? g.eta : '' %>" min="14" max="50" placeholder="es. 27" />
  </div>
  <div class="form-group">
    <label>Valore €</label>
    <input type="number" name="valore" value="<%= g && g.valore !== null ? Number(g.valore) : '' %>" min="0" step="0.5" placeholder="es. 12.5" />
  </div>
  <div class="form-group">
    <label>Stato</label>
    <select name="active">
      <option value="1" <%= !g || g.active ? 'selected' : '' %>>Attivo</option>
      <option value="0" <%= g && !g.active ? 'selected' : '' %>>Inattivo</option>
    </select>
  </div>
</div>
