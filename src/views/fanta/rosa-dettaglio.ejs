<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Rosa - ' + fantaTeam.nome }) %>
  <style>
    .back-link { font-size: .85rem; color: var(--green-mid); text-decoration: none; font-weight: 600; }
    .back-link:hover { text-decoration: underline; }

    .rosa-detail-header {
      display: flex; align-items: center; gap: 16px; margin-bottom: 20px; flex-wrap: wrap;
    }
    .rosa-detail-header h1 { margin: 0; }
    .rosa-detail-meta { font-size: .85rem; color: var(--gray-500); }

    .rosa-detail-table { border-collapse: collapse; width: 100%; }
    .rosa-detail-table th, .rosa-detail-table td {
      padding: 9px 12px; font-size: .82rem;
      border-bottom: 1px solid var(--gray-200);
    }
    .rosa-detail-table th {
      background: var(--gray-50); font-weight: 700; text-align: left;
      position: sticky; top: 0;
    }
    .rosa-detail-table tbody tr:hover { background: #f0fdf4; }

    .ruolo-dot {
      display: inline-block; width: 22px; height: 22px;
      line-height: 22px; text-align: center;
      border-radius: 50%; font-weight: 800; font-size: .68rem;
      color: #fff;
    }
    .ruolo-P { background: #64748b; }
    .ruolo-D { background: #2563eb; }
    .ruolo-C { background: #16a34a; }
    .ruolo-A { background: #dc2626; }

    .badge-tipo {
      display: inline-block; padding: 2px 8px; border-radius: 12px;
      font-size: .72rem; font-weight: 700;
    }
    .badge-Acquisto { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
    .badge-Prestito { background: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; }
    .badge-Cessione { background: #fef9c3; color: #854d0e; border: 1px solid #fde68a; }

    .badge-cat {
      display: inline-block; padding: 2px 8px; border-radius: 12px;
      font-size: .72rem; font-weight: 700;
    }
    .badge-InRosa { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
    .badge-FuoriRosa { background: #fef9c3; color: #854d0e; border: 1px solid #fde68a; }
    .badge-U21 { background: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; }

    .rosa-stats-row {
      display: flex; gap: 16px; margin-bottom: 20px; flex-wrap: wrap;
    }
    .rosa-stat-card {
      padding: 12px 18px; border-radius: 8px; font-size: .82rem;
      background: var(--gray-50); border: 1px solid var(--gray-200);
    }
    .rosa-stat-card strong { display: block; font-size: 1.1rem; color: var(--green-dark); }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container">
    <a href="/fanta/rose" class="back-link">← Torna alle Rose</a>

    <div class="rosa-detail-header" style="margin-top:12px;">
      <h1>🏟 <%= fantaTeam.nome %></h1>
      <span class="rosa-detail-meta">Presidente: <strong><%= presidente %></strong> · Stagione: <strong><%= stagione %></strong></span>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (isAnticipo) { %>
      <div class="alert" style="background:#fef9c3;border-left:4px solid #ca8a04;color:#78350f;font-size:.82rem;padding:10px 16px;border-radius:6px;margin-bottom:16px;">
        📅 <strong>Periodo rinnovi:</strong> gli anni contratto mostrati riflettono la situazione <em>dopo</em> il rollover di fine stagione. I contratti con <strong>0 anni</strong> sono in scadenza e richiedono rinnovo o svincolo.
      </div>
    <% } %>

    <%
      const totValore = giocatori.reduce((s, g) => s + (g.valore || 0), 0);
      const countInRosa = giocatori.filter(g => g.categoria === 'InRosa').length;
      const countFuoriRosa = giocatori.filter(g => g.categoria === 'FuoriRosa').length;
      const countU21 = giocatori.filter(g => g.categoria === 'U21').length;
    %>
    <div class="rosa-stats-row">
      <div class="rosa-stat-card">Giocatori<strong><%= giocatori.length %></strong></div>
      <div class="rosa-stat-card">In Rosa<strong><%= countInRosa %></strong></div>
      <div class="rosa-stat-card">Fuori Rosa<strong><%= countFuoriRosa %></strong></div>
      <div class="rosa-stat-card">U21<strong><%= countU21 %></strong></div>
      <div class="rosa-stat-card">Valore Totale<strong><%= totValore.toFixed(2) %> M</strong></div>
    </div>

    <% if (giocatori.length === 0) { %>
      <p style="color:var(--gray-400); font-style:italic;">Nessun giocatore con contratto valido.</p>
    <% } else { %>
    <div class="card" style="padding:0; overflow:hidden;">
      <table class="rosa-detail-table">
        <thead>
          <tr>
            <th>R</th>
            <th>Giocatore</th>
            <th>Squadra</th>
            <th>Età</th>
            <th>Valore</th>
            <th>Scadenza</th>
            <th>Anni Rim.</th>
            <th>Formula</th>
          </tr>
        </thead>
        <tbody>
          <%
            const inRosa = giocatori.filter(g => g.categoria === 'InRosa');
            const fuoriRosa = giocatori.filter(g => g.categoria === 'FuoriRosa');
            const u21 = giocatori.filter(g => g.categoria === 'U21');
          %>
          <% inRosa.forEach(function(g) { %>
          <tr>
            <td><span class="ruolo-dot ruolo-<%= g.ruolo %>"><%= g.ruolo %></span></td>
            <td><strong><%= g.nome %></strong></td>
            <td><%= g.squadra || '—' %></td>
            <td style="text-align:center;"><%= g.eta || '—' %></td>
            <td><%= g.valore ? g.valore.toFixed(2) : '—' %></td>
            <td style="text-align:center;"><%= g.dataFine || '—' %></td>
            <td style="text-align:center;<%= g.anniContratto <= 1 ? 'color:#dc2626;font-weight:700;' : '' %>"><%= g.anniContratto %></td>
            <td><span class="badge-tipo badge-<%= g.tipo %>"><%= g.tipo %></span></td>
          </tr>
          <% }) %>
          <% if (fuoriRosa.length > 0) { %>
          <tr class="section-separator">
            <td colspan="8" style="background:#fef9c3; font-weight:800; font-size:.78rem; color:#854d0e; padding:8px 12px; border-top:2px solid #fde68a;">
              Fuori Rosa (<%= fuoriRosa.length %>)
            </td>
          </tr>
          <% fuoriRosa.forEach(function(g) { %>
          <tr>
            <td><span class="ruolo-dot ruolo-<%= g.ruolo %>"><%= g.ruolo %></span></td>
            <td><strong><%= g.nome %></strong></td>
            <td><%= g.squadra || '—' %></td>
            <td style="text-align:center;"><%= g.eta || '—' %></td>
            <td><%= g.valore ? g.valore.toFixed(2) : '—' %></td>
            <td style="text-align:center;"><%= g.dataFine || '—' %></td>
            <td style="text-align:center;<%= g.anniContratto <= 1 ? 'color:#dc2626;font-weight:700;' : '' %>"><%= g.anniContratto %></td>
            <td><span class="badge-tipo badge-<%= g.tipo %>"><%= g.tipo %></span></td>
          </tr>
          <% }) %>
          <% } %>
          <% if (u21.length > 0) { %>
          <tr class="section-separator">
            <td colspan="8" style="background:#dbeafe; font-weight:800; font-size:.78rem; color:#1e40af; padding:8px 12px; border-top:2px solid #bfdbfe;">
              U21 (<%= u21.length %>)
            </td>
          </tr>
          <% u21.forEach(function(g) { %>
          <tr>
            <td><span class="ruolo-dot ruolo-<%= g.ruolo %>"><%= g.ruolo %></span></td>
            <td><strong><%= g.nome %></strong></td>
            <td><%= g.squadra || '—' %></td>
            <td style="text-align:center;"><%= g.eta || '—' %></td>
            <td><%= g.valore ? g.valore.toFixed(2) : '—' %></td>
            <td style="text-align:center;"><%= g.dataFine || '—' %></td>
            <td style="text-align:center;<%= g.anniContratto <= 1 ? 'color:#dc2626;font-weight:700;' : '' %>"><%= g.anniContratto %></td>
            <td><span class="badge-tipo badge-<%= g.tipo %>"><%= g.tipo %></span></td>
          </tr>
          <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</body>
</html>
