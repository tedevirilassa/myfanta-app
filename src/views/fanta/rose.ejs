<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Rose' }) %>
  <style>
    .team-section {
      margin-bottom: 8px;
      border: 1.5px solid var(--gray-200);
      border-radius: 10px;
      overflow: hidden;
    }
    .team-section summary {
      cursor: pointer;
      padding: 14px 20px;
      font-size: .95rem;
      font-weight: 800;
      color: var(--green-dark);
      display: flex;
      align-items: center;
      gap: 10px;
      background: #f8fafc;
      list-style: none;
    }
    .team-section summary::-webkit-details-marker { display: none; }
    .team-section summary::marker { display: none; content: ''; }
    .team-section summary::before {
      content: '▶'; font-size: .7rem;
      transition: transform .2s; display: inline-block;
    }
    .team-section[open] summary::before { transform: rotate(90deg); }

    .team-body { padding: 0 14px 14px; }

    .rosa-section-title {
      font-size: .72rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: .7px; color: var(--gray-400);
      padding: 10px 0 4px; border-bottom: 1px solid var(--gray-100);
      margin-top: 8px;
    }
    .rosa-section-title.fuorirosa { color: #854d0e; }
    .rosa-section-title.u21 { color: #1e40af; }

    .rosa-list { list-style: none; padding: 0; margin: 0; }
    .rosa-list li {
      display: flex; align-items: center; gap: 8px;
      padding: 5px 0; font-size: .82rem;
      border-bottom: 1px solid var(--gray-50);
    }
    .rosa-list li:last-child { border-bottom: none; }

    .ruolo-dot {
      display: inline-block; width: 22px; height: 22px;
      line-height: 22px; text-align: center;
      border-radius: 50%; font-weight: 800; font-size: .68rem;
      color: #fff; flex-shrink: 0;
    }
    .ruolo-P { background: #64748b; }
    .ruolo-D { background: #2563eb; }
    .ruolo-C { background: #16a34a; }
    .ruolo-A { background: #dc2626; }

    .g-nome { font-weight: 600; }
    .g-squadra { color: var(--gray-400); font-size: .75rem; margin-left: auto; }

    .team-footer {
      padding: 8px 0; font-size: .75rem; color: var(--gray-400);
      border-top: 1px solid var(--gray-100); text-align: right; margin-top: 8px;
    }

    .empty-section { padding: 8px 0; font-size: .78rem; color: var(--gray-300); font-style: italic; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container">
    <div class="page-header">
      <h1>📋 Rose — <%= stagione %></h1>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (roseData.length === 0) { %>
      <p style="color:var(--gray-400); font-style:italic;">Nessun team con giocatori trovato.</p>
    <% } else { %>
      <% roseData.forEach(function(team) { %>
      <details class="team-section">
        <summary>
          <span>🏟 <%= team.nome %></span>
          <% if (team.presidente) { %>
            <span style="font-size:.78rem;font-weight:500;color:var(--gray-400);">(<%= team.presidente %>)</span>
          <% } %>
          <span style="margin-left:auto;font-size:.78rem;font-weight:600;color:var(--gray-400);"><%= team.totale %> giocatori</span>
          <a href="/fanta/rose/<%= team.id %>" class="btn btn-primary btn-sm" style="font-size:.75rem;padding:4px 10px;margin-left:8px;" onclick="event.stopPropagation()">
            📊 Dettaglio
          </a>
        </summary>
        <div class="team-body">
          <div class="rosa-section-title">In Rosa (<%= team.inRosa.length %>)</div>
          <% if (team.inRosa.length === 0) { %>
            <div class="empty-section">Nessun giocatore</div>
          <% } else { %>
          <ul class="rosa-list">
            <% team.inRosa.forEach(function(g) { %>
            <li>
              <span class="ruolo-dot ruolo-<%= g.ruolo %>"><%= g.ruolo %></span>
              <span class="g-nome"><%= g.nome %></span>
              <span class="g-squadra"><%= g.squadra || '' %></span>
            </li>
            <% }) %>
          </ul>
          <% } %>

          <% if (team.fuoriRosa.length > 0) { %>
          <div class="rosa-section-title fuorirosa">Fuori Rosa (<%= team.fuoriRosa.length %>)</div>
          <ul class="rosa-list">
            <% team.fuoriRosa.forEach(function(g) { %>
            <li>
              <span class="ruolo-dot ruolo-<%= g.ruolo %>"><%= g.ruolo %></span>
              <span class="g-nome"><%= g.nome %></span>
              <span class="g-squadra"><%= g.squadra || '' %></span>
            </li>
            <% }) %>
          </ul>
          <% } %>

          <% if (team.u21.length > 0) { %>
          <div class="rosa-section-title u21">U21 (<%= team.u21.length %>)</div>
          <ul class="rosa-list">
            <% team.u21.forEach(function(g) { %>
            <li>
              <span class="ruolo-dot ruolo-<%= g.ruolo %>"><%= g.ruolo %></span>
              <span class="g-nome"><%= g.nome %></span>
              <span class="g-squadra"><%= g.squadra || '' %></span>
            </li>
            <% }) %>
          </ul>
          <% } %>

          <div class="team-footer">
            Totale: <%= team.totale %> giocatori
          </div>
        </div>
      </details>
      <% }) %>
    <% } %>
  </div>
</body>
</html>
