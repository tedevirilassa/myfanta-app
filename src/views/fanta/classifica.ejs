<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Situazione Patrimoniale' }) %>
  <style>
    .rank-1 td:first-child { color: var(--gold); font-weight: 900; font-size: 1.2rem; }
    .rank-2 td:first-child { color: #adb5bd; font-weight: 700; }
    .rank-3 td:first-child { color: #cd7f32; font-weight: 700; }
    .pm-pos { color: #15803d; font-weight: 700; }
    .pm-neg { color: #b91c1c; font-weight: 700; }
    .pm-zero{ color: #94a3b8; }
    .patrimonio-bar {
      height: 6px; border-radius: 3px;
      background: var(--green-light); display: block; margin-top: 4px;
      transition: width .3s;
    }
    .val-rose { font-size: .75rem; color: var(--gray-400); display: block; }
    th.sortable { cursor: pointer; user-select: none; white-space: nowrap; }
    th.sortable:hover { background: var(--gray-100); }
    th.sortable .sort-arrow { opacity: .35; margin-left: 4px; font-size: .75rem; }
    th.sortable.sort-active .sort-arrow { opacity: 1; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container">
    <div class="page-header">
      <h1>💰 Situazione Patrimoniale</h1>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>


    <% if (classifica.length > 0) {
      const maxPat = classifica[0].patrimonio;
    %>
    <div class="card" style="padding:0; overflow:hidden;">
      <table>
        <thead>
          <tr>
            <th style="width:40px;">#</th>
            <th>Presidente</th>
            <th class="sortable sort-active" data-sort-key="patrimonio" data-sort-dir="desc">Patrimonio<span class="sort-arrow">▼</span></th>
            <th class="sortable" data-sort-key="rosa" data-sort-dir="desc">Rosa<span class="sort-arrow">▼</span></th>
            <th class="sortable" data-sort-key="crediti" data-sort-dir="desc">Crediti<span class="sort-arrow">▼</span></th>
            <th>Giocatori</th>
            <th>Età media</th>
            <th>Prestiti IN</th>
          </tr>
        </thead>
        <tbody>
          <% classifica.forEach(function(p, idx) {
            const pos = idx + 1;
            const rowClass = pos === 1 ? 'rank-1' : pos === 2 ? 'rank-2' : pos === 3 ? 'rank-3' : '';
            const barWidth = Math.round((p.patrimonio / maxPat) * 100);
          %>
          <tr class="<%= rowClass %>" data-patrimonio="<%= p.patrimonio %>" data-rosa="<%= p.valoreRose %>" data-crediti="<%= p.crediti %>">
            <td class="rank-cell" style="text-align:center; font-weight:700;"><%= pos %></td>
            <td>
              <strong><%= p.nomePresidente %></strong>
              <% if (p.fantaTeam) { %>
                <span style="font-size:.8rem; color:var(--gray-500); display:block;">(<%= p.fantaTeam.nome %>)</span>
              <% } else { %>
                <span style="font-size:.78rem; color:var(--gray-300); display:block; font-style:italic;">NULL</span>
              <% } %>
            </td>
            <td>
              <strong><%= p.patrimonio.toFixed(2) %></strong>
              <span class="val-rose">Rosa: <%= p.valoreRose.toFixed(2) %></span>
              <span class="patrimonio-bar" style="width:<%= barWidth %>%"></span>
            </td>
            <td><%= p.valoreRose.toFixed(2) %></td>
            <td><%= p.crediti.toFixed(2) %></td>
            <td style="text-align:center;"><%= p.giocatoriTesserati %></td>
            <td style="text-align:center;"><%= p.etaMedia.toFixed(2) %></td>
            <td><%= p.montePrestiti.toFixed(2) %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- ── Admin: dettaglio rosa per team ── -->
    <% if (currentUser && currentUser.role === 'ADMIN' && typeof teamsPerCombobox !== 'undefined' && teamsPerCombobox && teamsPerCombobox.length > 0) { %>
    <div class="card" style="margin-top:24px; padding:18px 22px;">
      <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-bottom:14px;">
        <h2 style="margin:0; font-size:1rem;">🔍 Dettaglio rosa (admin)</h2>
        <form method="GET" action="/fanta/classifica" style="margin:0; display:flex; gap:8px; align-items:center;">
          <select name="teamDetail" onchange="this.form.submit()" style="padding:7px 10px; border-radius:6px; border:1.5px solid var(--gray-200);">
            <option value="">— Seleziona team —</option>
            <% teamsPerCombobox.forEach(function(t) { %>
              <option value="<%= t.id %>" <%= (teamDetail && teamDetail.team && teamDetail.team.id === t.id) ? 'selected' : '' %>>
                <%= t.nome %> (<%= t.nomePresidente %>)
              </option>
            <% }) %>
          </select>
          <% if (teamDetail) { %>
            <a href="/fanta/classifica" class="btn btn-sm" style="background:var(--gray-200); color:var(--gray-700);">Chiudi</a>
          <% } %>
        </form>
      </div>

      <% if (teamDetail) { %>
        <div style="margin-bottom:10px; font-size:.88rem; color:var(--gray-700);">
          Team: <strong><%= teamDetail.team.nome %></strong> ·
          Presidente: <strong><%= teamDetail.team.user ? (teamDetail.team.user.nickname || teamDetail.team.user.email) : '—' %></strong> ·
          Giocatori: <strong><%= teamDetail.giocatori.length %></strong> ·
          Valore rosa totale: <strong style="color:var(--green-dark);"><%= teamDetail.totaleValore.toFixed(2) %> M</strong>
        </div>
        <div class="table-wrap">
          <table style="width:100%;">
            <thead>
              <tr>
                <th>Ruolo</th>
                <th>Giocatore</th>
                <th>Squadra</th>
                <th style="text-align:center;">Età</th>
                <th style="text-align:right;">Valore TM (M)</th>
                <th style="text-align:right;">Stipendio (M)</th>
              </tr>
            </thead>
            <tbody>
              <% teamDetail.giocatori.forEach(function(g) { %>
                <tr style="<%= g.active === false ? 'background:#fef2f2;' : '' %>">
                  <td><span style="display:inline-block; width:24px; height:24px; line-height:24px; text-align:center; border-radius:50%; font-weight:800; color:#fff; font-size:.72rem;
                    <%= g.ruolo==='P'?'background:#64748b;':g.ruolo==='D'?'background:#2563eb;':g.ruolo==='C'?'background:#16a34a;':'background:#dc2626;' %>"><%= g.ruolo %></span></td>
                  <td>
                    <strong><%= g.nome %></strong>
                    <% if (g.active === false) { %>
                      <span style="margin-left:6px; padding:1px 7px; border-radius:999px; background:var(--red-light); color:var(--red); font-size:.65rem; font-weight:800;">INATTIVO</span>
                    <% } %>
                  </td>
                  <td style="color:var(--gray-700);"><%= g.squadra || '—' %></td>
                  <td style="text-align:center;"><%= g.eta != null ? g.eta : '—' %></td>
                  <td style="text-align:right; font-weight:700;"><%= g.valore.toFixed(2) %></td>
                  <td style="text-align:right; color:var(--gray-700);"><%= g.stipendio > 0 ? g.stipendio.toFixed(2) : '—' %></td>
                </tr>
              <% }) %>
              <tr style="background:var(--green-pale); font-weight:800;">
                <td colspan="4" style="text-align:right;">TOTALE</td>
                <td style="text-align:right; color:var(--green-dark);"><%= teamDetail.totaleValore.toFixed(2) %> M</td>
                <td></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div style="margin-top:10px; font-size:.75rem; color:var(--gray-400);">
          Somma dei <code>giocatore.valore</code> (ultima quotazione TM) di tutti i giocatori <code>active=true</code>
          sotto contratto Acquisto <code>valido=true</code> del team. Dedotti per giocatoreId.
        </div>
      <% } else { %>
        <div style="font-size:.85rem; color:var(--gray-400);">Seleziona una rosa per visualizzare la composizione e i valori che compongono il "Valore rosa" della classifica.</div>
      <% } %>
    </div>
    <% } %>

    <!-- stat cards -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:16px; margin-top:24px;">
      <% 
        const roseValues = classifica.map(p => p.valoreRose);
        const maxRosa = Math.max(...roseValues);
        const minRosa = Math.min(...roseValues);
        const quotaRinnovi = Math.round(((maxRosa + minRosa) / 2) * salaryCapPct * 100) / 100;
        const leader = classifica[0];
        const bestPM = [...classifica].sort((a,b)=>b.ultimoPlusMinus-a.ultimoPlusMinus)[0];
        const mostPlayers = [...classifica].sort((a,b)=>b.giocatoriTesserati-a.giocatoriTesserati)[0];
      %>
      <div class="card" style="padding:20px;">
        <div style="font-size:.75rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px;">Quota Rinnovi</div>
        <div style="font-size:1.5rem; font-weight:800; color:var(--green-dark);"><%= quotaRinnovi.toFixed(2) %></div>
        <div style="font-size:.72rem; color:var(--gray-400); margin-top:4px;"><%= Math.round(salaryCapPct * 100) %>% media tra max (<%= maxRosa.toFixed(2) %>) e min (<%= minRosa.toFixed(2) %>)</div>
      </div>
      <div class="card" style="padding:20px;">
        <div style="font-size:.75rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px;">Leader</div>
        <div style="font-size:1.3rem; font-weight:800; color:var(--green-dark);">🥇 <%= leader.nomePresidente %></div>
        <div style="font-size:.85rem; color:var(--gray-400);"><%= leader.patrimonio.toFixed(2) %></div>
      </div>
      <div class="card" style="padding:20px;">
        <div style="font-size:.75rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px;">Miglior ± recente</div>
        <div style="font-size:1.3rem; font-weight:800; color:var(--green-dark);">⚡ <%= bestPM.nomePresidente %></div>
        <div style="font-size:.85rem; color:#15803d; font-weight:700;">+<%= bestPM.ultimoPlusMinus.toFixed(2) %></div>
      </div>
      <div class="card" style="padding:20px;">
        <div style="font-size:.75rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px;">Più giocatori</div>
        <div style="font-size:1.3rem; font-weight:800; color:var(--green-dark);">👥 <%= mostPlayers.nomePresidente %></div>
        <div style="font-size:.85rem; color:var(--gray-400);"><%= mostPlayers.giocatoriTesserati %> tesserati</div>
      </div>
    </div>
    <% } %>

  </div>

  <script>
    (function() {
      const table = document.querySelector('.card table');
      if (!table) return;
      const tbody = table.querySelector('tbody');
      const headers = table.querySelectorAll('th.sortable');

      function applySort(key, dir) {
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const mult = dir === 'asc' ? 1 : -1;
        rows.sort((a, b) => {
          const va = parseFloat(a.dataset[key]) || 0;
          const vb = parseFloat(b.dataset[key]) || 0;
          return (va - vb) * mult;
        });
        rows.forEach((r, i) => {
          const pos = i + 1;
          r.classList.remove('rank-1', 'rank-2', 'rank-3');
          if (pos === 1) r.classList.add('rank-1');
          else if (pos === 2) r.classList.add('rank-2');
          else if (pos === 3) r.classList.add('rank-3');
          const rc = r.querySelector('.rank-cell');
          if (rc) rc.textContent = pos;
          tbody.appendChild(r);
        });
      }

      headers.forEach(h => {
        h.addEventListener('click', () => {
          const key = h.dataset.sortKey;
          const currentDir = h.dataset.sortDir;
          const isActive = h.classList.contains('sort-active');
          const newDir = isActive ? (currentDir === 'desc' ? 'asc' : 'desc') : 'desc';
          headers.forEach(o => {
            o.classList.remove('sort-active');
            const arr = o.querySelector('.sort-arrow');
            if (arr) arr.textContent = '▼';
            o.dataset.sortDir = 'desc';
          });
          h.classList.add('sort-active');
          h.dataset.sortDir = newDir;
          const arrow = h.querySelector('.sort-arrow');
          if (arrow) arrow.textContent = newDir === 'asc' ? '▲' : '▼';
          applySort(key, newDir);
        });
      });
    })();
  </script>
</body>
</html>
