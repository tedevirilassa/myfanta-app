<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Situazione Patrimoniale' }) %>
  <style>
    .rank-1 td:first-child { color: var(--gold); font-weight: 900; font-size: 1.2rem; }
    .rank-2 td:first-child { color: #adb5bd; font-weight: 700; }
    .rank-3 td:first-child { color: #cd7f32; font-weight: 700; }
    .pm-pos { color: #15803d; font-weight: 700; }
    .pm-neg { color: #b91c1c; font-weight: 700; }
    .pm-zero{ color: #94a3b8; }
    .patrimonio-bar {
      height: 6px; border-radius: 3px;
      background: var(--green-light); display: block; margin-top: 4px;
      transition: width .3s;
    }
    .val-rose { font-size: .75rem; color: var(--gray-400); display: block; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container">
    <div class="page-header">
      <h1>💰 Situazione Patrimoniale</h1>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (stagioni.length > 0) { %>
    <div style="margin-bottom:20px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <label style="font-weight:700; font-size:.85rem;">Stagione:</label>
      <% stagioni.forEach(function(s) { %>
        <a href="/fanta/classifica?stagione=<%= encodeURIComponent(s) %>"
           class="btn btn-sm <%= s === stagioneFiltro ? 'btn-primary' : '' %>"
           style="<%= s !== stagioneFiltro ? 'background:var(--gray-100);color:var(--gray-700);border:1.5px solid var(--gray-200);' : '' %>">
          <%= s %>
        </a>
      <% }) %>
    </div>
    <% } %>

    <% if (classifica.length > 0) {
      const maxPat = classifica[0].patrimonio;
    %>
    <div class="card" style="padding:0; overflow:hidden;">
      <table>
        <thead>
          <tr>
            <th style="width:40px;">#</th>
            <th>Presidente</th>
            <th>Patrimonio</th>
            <th>Rosa</th>
            <th>Crediti</th>
            <th>Giocatori</th>
            <th>Età media</th>
            <th>Stipendi</th>
            <th>Prestiti IN</th>
            <th>Ultimo ±</th>
          </tr>
        </thead>
        <tbody>
          <% classifica.forEach(function(p, idx) {
            const pos = idx + 1;
            const rowClass = pos === 1 ? 'rank-1' : pos === 2 ? 'rank-2' : pos === 3 ? 'rank-3' : '';
            const barWidth = Math.round((p.patrimonio / maxPat) * 100);
            const pmClass = p.ultimoPlusMinus > 0 ? 'pm-pos' : p.ultimoPlusMinus < 0 ? 'pm-neg' : 'pm-zero';
          %>
          <tr class="<%= rowClass %>">
            <td style="text-align:center; font-weight:700;"><%= pos %></td>
            <td>
              <strong><%= p.nomePresidente %></strong>
              <% if (p.fantaTeam) { %>
                <span style="font-size:.8rem; color:var(--gray-500); display:block;">(<%= p.fantaTeam.nome %>)</span>
              <% } else { %>
                <span style="font-size:.78rem; color:var(--gray-300); display:block; font-style:italic;">NULL</span>
              <% } %>
            </td>
            <td>
              <strong><%= p.patrimonio.toFixed(2) %></strong>
              <span class="val-rose">Rosa: <%= p.valoreRose.toFixed(2) %></span>
              <span class="patrimonio-bar" style="width:<%= barWidth %>%"></span>
            </td>
            <td><%= p.valoreRose.toFixed(2) %></td>
            <td><%= p.crediti.toFixed(2) %></td>
            <td style="text-align:center;"><%= p.giocatoriTesserati %></td>
            <td style="text-align:center;"><%= p.etaMedia.toFixed(2) %></td>
            <td><%= p.stipendi.toFixed(2) %></td>
            <td><%= p.montePrestiti.toFixed(2) %></td>
            <td class="<%= pmClass %>">
              <%= p.ultimoPlusMinus > 0 ? '+' : '' %><%= p.ultimoPlusMinus.toFixed(2) %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- stat cards -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:16px; margin-top:24px;">
      <% 
        const roseValues = classifica.map(p => p.valoreRose);
        const maxRosa = Math.max(...roseValues);
        const minRosa = Math.min(...roseValues);
        const quotaRinnovi = Math.round(((maxRosa + minRosa) / 2) * 0.25 * 100) / 100;
        const leader = classifica[0];
        const bestPM = [...classifica].sort((a,b)=>b.ultimoPlusMinus-a.ultimoPlusMinus)[0];
        const mostPlayers = [...classifica].sort((a,b)=>b.giocatoriTesserati-a.giocatoriTesserati)[0];
      %>
      <div class="card" style="padding:20px;">
        <div style="font-size:.75rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px;">Quota Rinnovi</div>
        <div style="font-size:1.5rem; font-weight:800; color:var(--green-dark);"><%= quotaRinnovi.toFixed(2) %></div>
        <div style="font-size:.72rem; color:var(--gray-400); margin-top:4px;">25% media tra max (<%= maxRosa.toFixed(2) %>) e min (<%= minRosa.toFixed(2) %>)</div>
      </div>
      <div class="card" style="padding:20px;">
        <div style="font-size:.75rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px;">Leader</div>
        <div style="font-size:1.3rem; font-weight:800; color:var(--green-dark);">🥇 <%= leader.nomePresidente %></div>
        <div style="font-size:.85rem; color:var(--gray-400);"><%= leader.patrimonio.toFixed(2) %></div>
      </div>
      <div class="card" style="padding:20px;">
        <div style="font-size:.75rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px;">Miglior ± recente</div>
        <div style="font-size:1.3rem; font-weight:800; color:var(--green-dark);">⚡ <%= bestPM.nomePresidente %></div>
        <div style="font-size:.85rem; color:#15803d; font-weight:700;">+<%= bestPM.ultimoPlusMinus.toFixed(2) %></div>
      </div>
      <div class="card" style="padding:20px;">
        <div style="font-size:.75rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px;">Più giocatori</div>
        <div style="font-size:1.3rem; font-weight:800; color:var(--green-dark);">👥 <%= mostPlayers.nomePresidente %></div>
        <div style="font-size:.85rem; color:var(--gray-400);"><%= mostPlayers.giocatoriTesserati %> tesserati</div>
      </div>
    </div>
    <% } %>

    <p style="margin-top:20px; font-size:.78rem; color:var(--gray-400); text-align:right;">
      Stagione: <strong><%= stagioneFiltro %></strong> · Dati importati dal foglio riepilogoEx
    </p>
  </div>
</body>
</html>
