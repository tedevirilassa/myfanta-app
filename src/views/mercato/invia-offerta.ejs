<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Invia Offerta' }) %>
  <style>
    .form-card { background:#fff; border-radius:10px; padding:28px 32px; box-shadow:0 2px 10px rgba(26,58,42,.08); }
    .range-bar { background:#f0fdf4; border:1.5px solid var(--green-light); border-radius:8px; padding:12px 16px; margin-bottom:18px; font-size:.88rem; }
    .range-bar strong { color:var(--green-dark); }
    .gioc-select-wrap { position:relative; }
    .player-row { display:flex; justify-content:space-between; align-items:center; }
    .player-badge { font-size:.72rem; font-weight:700; padding:2px 7px; border-radius:10px; background:var(--gray-100); color:var(--gray-600); }
    label { display:block; font-weight:700; font-size:.82rem; color:var(--gray-700); margin-bottom:5px; margin-top:14px; }
    select, input[type=number] {
      width:100%; padding:10px 12px; border:1.5px solid var(--gray-200);
      border-radius:8px; font-size:.9rem; background:#fafdfa; outline:none;
    }
    select:focus, input[type=number]:focus { border-color:var(--green-mid); box-shadow:0 0 0 2px rgba(45,106,79,.15); }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container" style="max-width:680px;">
    <div class="page-header">
      <h1>📨 Invia Offerta di Mercato</h1>
      <a href="/mercato/inbox" class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-700);">📬 Inbox</a>
    </div>

    <% if (error) { %><div class="alert alert-error">❌ <%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success">✅ Offerta inviata con successo!</div><% } %>

    <div class="form-card">
      <!-- Step 1: scegli team avversario (ricarica pagina) -->
      <form method="GET" action="/mercato/invia-offerta" id="form-team">
        <label for="teamId">Team avversario</label>
        <select name="teamId" id="teamId" onchange="this.form.submit()">
          <option value="">— Seleziona un team —</option>
          <% altriTeam.forEach(t => { %>
            <option value="<%= t.id %>" <%= preselTeamId === t.id ? 'selected' : '' %>>
              <%= t.nome %><% if (t.user) { %> (<%= t.user.nickname || t.user.email.split('@')[0] %>)<% } %>
            </option>
          <% }) %>
        </select>
      </form>

      <% if (preselTeamId && giocatoriTeamSelezionato.length > 0) { %>
        <form id="form-offerta">
          <input type="hidden" name="fantaTeamRiceventeId" value="<%= preselTeamId %>">

          <label for="giocatoreId">Giocatore</label>
          <select name="giocatoreId" id="giocatoreId" onchange="aggiornaPrezzi()">
            <option value="">— Seleziona —</option>
            <% giocatoriTeamSelezionato.forEach(g => { %>
              <option value="<%= g.giocatoreId %>"
                      data-valore="<%= g.valore != null ? g.valore : '' %>">
                [<%= g.ruolo %>] <%= g.nome %>
                <% if (g.squadra) { %> — <%= g.squadra %><% } %>
                <% if (g.valore != null) { %> (<%=  g.valore.toFixed(2) %> M)<% } else { %> (valore n/d)<% } %>
              </option>
            <% }) %>
          </select>

          <div id="range-bar" class="range-bar" style="display:none;">
            Range consentito (±<%= Math.round(delta * 100) %>%):
            <strong id="range-min">—</strong> M ÷ <strong id="range-max">—</strong> M
            &nbsp;|&nbsp; Valore TM: <strong id="range-ref">—</strong> M
          </div>

          <label for="importoOfferta">Offerta (M)</label>
          <input type="number" name="importoOfferta" id="importoOfferta"
                 step="0.01" min="0" placeholder="es. 12.50" required
                 oninput="aggiornaHintClausola()">

          <label for="tipoContratto">Tipo contratto</label>
          <select name="tipoContratto" id="tipoContratto" onchange="aggiornaClasuole()">
            <option value="Acquisto">Acquisto</option>
            <option value="Prestito">Prestito</option>
          </select>

          <label for="clausola">Clausola speciale <span style="font-weight:400;color:var(--gray-400);">(opzionale)</span></label>
          <select name="clausola" id="clausola" onchange="aggiornaHintClausola()">
            <option value="">— Nessuna clausola —</option>
            <optgroup label="Solo su Acquisto" id="grp-ricompra">
              <option value="DirittoRicompra">Diritto di Ricompra</option>
              <option value="ObbligoRicompra">Obbligo di Ricompra</option>
            </optgroup>
            <optgroup label="Solo su Prestito" id="grp-riscatto">
              <option value="DirittoRiscatto">Diritto di Riscatto</option>
              <option value="ObbligoRiscatto">Obbligo di Riscatto</option>
            </optgroup>
          </select>

          <div id="clausola-wrap" style="display:none;">
            <label for="importoClausola">Importo clausola (M)</label>
            <input type="number" name="importoClausola" id="importoClausola"
                   step="0.01" min="0" placeholder="es. 18.00"
                   oninput="aggiornaHintClausola()">
            <div id="clausola-hint" style="font-size:.72rem;color:var(--gray-400);margin-top:3px;"></div>
          </div>

          <label for="dataDecorrenza">Data decorrenza (MM-YYYY)</label>
          <input type="text" name="dataDecorrenza" id="dataDecorrenza"
                 pattern="\d{2}-\d{4}" placeholder="es. 01-2027" required
                 style="width:100%; padding:10px 12px; border:1.5px solid var(--gray-200); border-radius:8px; font-size:.9rem; background:#fafdfa;">
          <div style="font-size:.72rem; color:var(--gray-400); margin-top:3px;">
            Mese in cui l'operazione diventerà effettiva. Deve rientrare nella finestra di mercato privato.
          </div>

          <label for="anniContrattoProposti">Durata contratto proposta (anni)</label>
          <select name="anniContrattoProposti" id="anniContrattoProposti" required>
            <option value="1">1 anno</option>
            <option value="2" selected>2 anni</option>
            <option value="3">3 anni</option>
          </select>

          <label for="categoriaProposta">Categoria in rosa proposta</label>
          <select name="categoriaProposta" id="categoriaProposta" required>
            <option value="InRosa">In Rosa</option>
            <option value="FuoriRosa">Fuori Rosa</option>
            <option value="U21">U21</option>
          </select>

          <div style="margin-top:22px;">
            <button type="submit" class="btn btn-success" id="btn-offerta">
              📨 Invia Offerta
            </button>
            <span id="offerta-spinner" style="display:none; font-size:.85rem; color:var(--gray-500); margin-left:10px;">Invio in corso…</span>
          </div>
          <div id="offerta-error" class="alert alert-error" style="display:none; margin-top:12px;"></div>
        </form>

      <% } else if (preselTeamId) { %>
        <p style="color:var(--gray-500); margin-top:16px; font-size:.88rem;">
          Il team selezionato non ha giocatori con contratto Acquisto attivo.
        </p>
      <% } %>
    </div>
  </div>

  <script>
    const DELTA    = parseFloat('<%= delta %>');
    const MIN_PCT  = parseFloat('<%= params.contratto_prezzo_min_pct || "0.60" %>');
    const MAX_PCT  = parseFloat('<%= params.contratto_prezzo_max_pct || "1.40" %>');

    let _valoreRif = 0;

    function aggiornaPrezzi() {
      const sel = document.getElementById('giocatoreId');
      const opt = sel.options[sel.selectedIndex];
      _valoreRif = parseFloat(opt?.dataset?.valore) || 0;
      const bar = document.getElementById('range-bar');

      if (!_valoreRif) { bar.style.display = 'none'; return; }

      const minV = (_valoreRif * (1 - DELTA)).toFixed(2);
      const maxV = (_valoreRif * (1 + DELTA)).toFixed(2);
      document.getElementById('range-min').textContent = minV;
      document.getElementById('range-max').textContent = maxV;
      document.getElementById('range-ref').textContent = _valoreRif.toFixed(2);
      document.getElementById('importoOfferta').min   = minV;
      document.getElementById('importoOfferta').max   = maxV;
      document.getElementById('importoOfferta').value = _valoreRif.toFixed(2);
      bar.style.display = 'block';
      aggiornaClasuole();
      aggiornaHintClausola();
    }

    function aggiornaClasuole() {
      const tipo = document.getElementById('tipoContratto').value;
      const sel  = document.getElementById('clausola');
      const grpR = document.getElementById('grp-riscatto');
      const grpC = document.getElementById('grp-ricompra');

      // Nascondi gruppi non compatibili e deseleziona se necessario
      if (tipo === 'Acquisto') {
        grpR.style.display = 'none';
        grpC.style.display = '';
        if (['DirittoRiscatto','ObbligoRiscatto'].includes(sel.value)) sel.value = '';
      } else {
        grpC.style.display = 'none';
        grpR.style.display = '';
        if (['DirittoRicompra','ObbligoRicompra'].includes(sel.value)) sel.value = '';
      }
      aggiornaHintClausola();
    }

    function aggiornaHintClausola() {
      const clausola = document.getElementById('clausola').value;
      const wrap     = document.getElementById('clausola-wrap');
      const hint     = document.getElementById('clausola-hint');

      if (!clausola) { wrap.style.display = 'none'; return; }
      wrap.style.display = 'block';

      const RISCATTI = ['DirittoRiscatto', 'ObbligoRiscatto'];
      const base = RISCATTI.includes(clausola)
        ? _valoreRif
        : parseFloat(document.getElementById('importoOfferta').value) || 0;

      if (!base) { hint.textContent = ''; return; }

      const minC = (base * MIN_PCT).toFixed(2);
      const maxC = (base * MAX_PCT).toFixed(2);
      const tipo = RISCATTI.includes(clausola) ? 'riscatto' : 'ricompra';
      const baseLbl = RISCATTI.includes(clausola)
        ? `valore TM (${base.toFixed(2)} M)`
        : `importo offerta (${base.toFixed(2)} M)`;
      hint.textContent = `L'importo di ${tipo} deve essere compreso tra ${minC} M e ${maxC} M (${Math.round(MIN_PCT*100)}%–${Math.round(MAX_PCT*100)}% del ${baseLbl}).`;

      document.getElementById('importoClausola').min = minC;
      document.getElementById('importoClausola').max = maxC;
    }

    document.getElementById('form-offerta')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('btn-offerta');
      const spinner = document.getElementById('offerta-spinner');
      const errEl  = document.getElementById('offerta-error');
      errEl.style.display = 'none';
      btn.disabled = true; spinner.style.display = 'inline';

      const fd = new FormData(this);
      const body = Object.fromEntries(fd.entries());

      try {
        const r = await fetch('/mercato/offerta', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await r.json();
        if (data.ok) {
          window.location.href = '/mercato/invia-offerta?success=1';
        } else {
          errEl.textContent = data.error || 'Errore sconosciuto.';
          errEl.style.display = 'block';
        }
      } catch(err) {
        errEl.textContent = 'Errore di rete: ' + err.message;
        errEl.style.display = 'block';
      } finally {
        btn.disabled = false; spinner.style.display = 'none';
      }
    });
  </script>
</body>
</html>
