<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Situazione Finanziaria' }) %>
  <style>
    .sf-table-wrap { overflow-x: auto; }

    .sf-table { min-width: 900px; border-collapse: collapse; width: 100%; }
    .sf-table th, .sf-table td {
      padding: 9px 12px; text-align: right; font-size: .85rem;
      border-bottom: 1px solid var(--gray-200);
    }
    .sf-table th { background: var(--gray-50); font-weight: 700; text-align: right; }
    .sf-table th:first-child, .sf-table td:first-child,
    .sf-table th:nth-child(2), .sf-table td:nth-child(2),
    .sf-table th:nth-child(3), .sf-table td:nth-child(3) { text-align: left; }
    .sf-table tbody tr:hover { background: #f0fdf4; }

    .badge-assoc {
      display: inline-block; padding: 2px 9px; border-radius: 20px;
      font-size: .72rem; font-weight: 700;
      background: #dcfce7; color: #166534; border: 1px solid #bbf7d0;
    }
    .badge-noassoc {
      display: inline-block; padding: 2px 9px; border-radius: 20px;
      font-size: .72rem; font-weight: 700;
      background: #fef9c3; color: #854d0e; border: 1px solid #fde68a;
    }

    .inline-form { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
    .inline-form select {
      padding: 4px 8px; border: 1.5px solid var(--gray-200);
      border-radius: 6px; font-size: .8rem; background: #fafdfa;
    }
    .inline-form .btn-xs {
      padding: 4px 10px; font-size: .78rem; font-weight: 700;
      background: var(--green-mid); color: #fff;
      border: none; border-radius: 6px; cursor: pointer;
    }
    .inline-form .btn-xs:hover { background: var(--green-dark); }

    .stagione-filter { display: flex; gap: 10px; align-items: center; margin-bottom: 20px; flex-wrap: wrap; }
    .stagione-filter select {
      padding: 7px 12px; border: 1.5px solid var(--gray-200);
      border-radius: 8px; font-size: .85rem; background: #fafdfa;
    }

    .num { font-variant-numeric: tabular-nums; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container">
    <div class="page-header">
      <h1>💰 Situazione Finanziaria</h1>
    </div>

    <% if (message) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="stagione-filter">
      <label for="filtroStagione" style="font-weight:700;font-size:.85rem;">Stagione:</label>
      <select id="filtroStagione" onchange="filtraStagione(this.value)">
        <option value="">— tutte —</option>
        <% stagioni.forEach(function(s) { %>
          <option value="<%= s %>"><%= s %></option>
        <% }) %>
      </select>
    </div>

    <div class="card" style="padding:0; overflow:hidden;">
      <div class="sf-table-wrap">
        <table class="sf-table">
          <thead>
            <tr>
              <th>Stagione</th>
              <th>Presidente</th>
              <th>FantaTeam</th>
              <th>Valore Rosa</th>
              <th>Crediti</th>
              <th>Patrimonio</th>
              <th>Giocatori</th>
              <th>Età Media</th>
              <th>Stipendi</th>
              <th>Prestiti IN</th>
              <th>+/−</th>
              <th>Associa</th>
            </tr>
          </thead>
          <tbody id="sfTableBody">
            <% situazioni.forEach(function(sf) { %>
            <tr data-stagione="<%= sf.stagione %>">
              <td><strong><%= sf.stagione %></strong></td>
              <td><strong><%= sf.nomePresidente %></strong></td>
              <td>
                <% if (sf.fantaTeam) { %>
                  <span class="badge badge-assoc"><%= sf.fantaTeam.nome %></span>
                <% } else { %>
                  <span class="badge badge-noassoc">non assegnato</span>
                <% } %>
              </td>
              <td class="num">€ <%= parseFloat(sf.valoreRose).toFixed(2) %></td>
              <td class="num">€ <%= parseFloat(sf.crediti).toFixed(2) %></td>
              <td class="num" style="font-weight:700;">€ <%= parseFloat(sf.patrimonio).toFixed(2) %></td>
              <td class="num"><%= sf.giocatoriTesserati %></td>
              <td class="num"><%= parseFloat(sf.etaMedia).toFixed(2) %></td>
              <td class="num">€ <%= parseFloat(sf.stipendi).toFixed(2) %></td>
              <td class="num">€ <%= parseFloat(sf.montePrestiti).toFixed(2) %></td>
              <td class="num" style="color:<%= parseFloat(sf.ultimoPlusMinus) >= 0 ? '#166534' : '#b91c1c' %>">
                <%= parseFloat(sf.ultimoPlusMinus) >= 0 ? '+' : '' %><%= parseFloat(sf.ultimoPlusMinus).toFixed(2) %>
              </td>
              <td>
                <form action="/admin/situazione-finanziaria/<%= sf.id %>/assign" method="POST" class="inline-form">
                  <select name="fantaTeamId">
                    <option value="">— nessuno —</option>
                    <% fantaTeams.forEach(function(ft) { %>
                      <option value="<%= ft.id %>" <%= sf.fantaTeamId === ft.id ? 'selected' : '' %>>
                        <%= ft.nome %>
                      </option>
                    <% }) %>
                  </select>
                  <button type="submit" class="btn-xs">Salva</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <p style="margin-top:16px; font-size:.8rem; color:var(--gray-400);">
      Totale snapshot: <strong><%= situazioni.length %></strong> &nbsp;|&nbsp;
      Import dati: <code>node scripts/import-riepilogoEx.js</code> &nbsp;
      (aggiorna stagione con <code>--stagione=2024-2025</code>)
    </p>
  </div>

  <script>
    function filtraStagione(val) {
      document.querySelectorAll('#sfTableBody tr').forEach(function(tr) {
        tr.style.display = (!val || tr.dataset.stagione === val) ? '' : 'none';
      });
    }
  </script>
</body>
</html>
