<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Situazione Finanziaria' }) %>
  <style>
    .sf-list { list-style: none; padding: 0; margin: 0; }
    .sf-list li {
      display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
      padding: 12px 16px;
      border-bottom: 1px solid var(--gray-200);
    }
    .sf-list li:last-child { border-bottom: none; }
    .sf-list li:hover { background: #f0fdf4; }

    .pres-name { font-weight: 700; font-size: .9rem; min-width: 160px; }
    .pres-crediti { font-size: .82rem; color: var(--gray-500); min-width: 100px; font-variant-numeric: tabular-nums; }

    .crediti-form { display: flex; gap: 5px; align-items: center; flex-wrap: nowrap; }
    .crediti-form input[type="number"] {
      width: 75px; padding: 5px 7px; border: 1.5px solid var(--gray-200);
      border-radius: 6px; font-size: .82rem; text-align: right;
    }
    .crediti-form input[type="text"] {
      width: 130px; padding: 5px 7px; border: 1.5px solid var(--gray-200);
      border-radius: 6px; font-size: .82rem;
    }
    .crediti-form .btn-plus {
      padding: 5px 10px; font-size: .82rem; font-weight: 700;
      background: #27ae60; color: #fff;
      border: none; border-radius: 6px; cursor: pointer;
    }
    .crediti-form .btn-plus:hover { background: #1e8449; }

    .stagione-filter { display: flex; gap: 10px; align-items: center; margin-bottom: 20px; flex-wrap: wrap; }
    .stagione-filter select {
      padding: 7px 12px; border: 1.5px solid var(--gray-200);
      border-radius: 8px; font-size: .85rem; background: #fafdfa;
    }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container">
    <div class="page-header">
      <h1>💰 Situazione Finanziaria</h1>
    </div>

    <% if (message) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="stagione-filter">
      <label for="filtroStagione" style="font-weight:700;font-size:.85rem;">Stagione:</label>
      <select id="filtroStagione" onchange="filtraStagione(this.value)">
        <option value="">— tutte —</option>
        <% stagioni.forEach(function(s) { %>
          <option value="<%= s %>"><%= s %></option>
        <% }) %>
      </select>
    </div>

    <div class="card" style="padding:0; overflow:hidden;">
      <ul class="sf-list" id="sfList">
        <% situazioni.forEach(function(sf) { %>
        <li data-stagione="<%= sf.stagione %>">
          <span class="pres-name"><%= sf.nomePresidente %></span>
          <span class="pres-crediti">Crediti: € <%= parseFloat(sf.crediti).toFixed(2) %></span>
          <form action="/admin/situazione-finanziaria/<%= sf.id %>/crediti" method="POST" class="crediti-form">
            <input type="number" name="importo" step="0.01" placeholder="± M" required title="Positivo per aggiungere, negativo per togliere">
            <input type="text" name="motivo" placeholder="Motivo">
            <button type="submit" class="btn-plus" title="Applica">$±</button>
          </form>
        </li>
        <% }) %>
      </ul>
    </div>
  </div>

  <script>
    function filtraStagione(val) {
      document.querySelectorAll('#sfList li').forEach(function(li) {
        li.style.display = (!val || li.dataset.stagione === val) ? '' : 'none';
      });
    }
  </script>
</body>
</html>
