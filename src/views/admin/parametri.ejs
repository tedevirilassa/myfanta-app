<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Parametri' }) %>
  <style>
    .param-grid {
      display: grid; gap: 16px;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    }
    .param-card {
      background: var(--white); border-radius: 10px;
      padding: 18px 20px;
      box-shadow: 0 2px 10px rgba(26,58,42,.07);
      border-left: 4px solid var(--green-mid);
    }
    .param-key {
      font-size: .72rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: .5px; color: var(--gray-400); margin-bottom: 4px;
      word-break: break-all;
    }
    .param-desc {
      font-size: .82rem; color: var(--gray-700); margin-bottom: 10px;
      line-height: 1.4;
    }
    .param-form {
      display: flex; gap: 8px; align-items: center;
    }
    .param-form input {
      flex: 1; padding: 7px 12px;
      border: 1.5px solid var(--gray-200); border-radius: 7px;
      font-size: .88rem; background: #fafdfa; outline: none;
    }
    .param-form input:focus {
      border-color: var(--green-mid);
      box-shadow: 0 0 0 2px rgba(45,106,79,.12);
    }
    .param-form button {
      padding: 7px 14px; font-size: .82rem; font-weight: 700;
      background: var(--green-mid); color: #fff;
      border: none; border-radius: 7px; cursor: pointer;
    }
    .param-form button:hover { background: var(--green-dark); }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container" style="max-width:1100px;">
    <div class="page-header">
      <h1>⚙️ Parametri di Gioco</h1>
      <a href="/admin/pannello" class="btn btn-sm" style="border:1.5px solid var(--gray-200);background:#fff;">
        ← Pannello
      </a>
    </div>

    <% if (message) { %>
      <div class="alert alert-success">✔ <%= message %></div>
    <% } %>

    <%
      // Raggruppa parametri per sezione in base al prefisso della chiave
      const sezioni = {
        'Rosa':      { icon: '👥', params: [] },
        'Prestiti':  { icon: '🔄', params: [] },
        'Contratti': { icon: '📝', params: [] },
        'Stipendi':  { icon: '💰', params: [] },
        'Mercato':   { icon: '🏪', params: [] },
        'Stagione':  { icon: '📅', params: [] },
        'Budget':    { icon: '💵', params: [] },
        'Altro':     { icon: '⚙️', params: [] },
      };
      parametri.forEach(function(p) {
        const k = p.chiave;
        if (k.startsWith('rosa_'))        sezioni['Rosa'].params.push(p);
        else if (k.startsWith('prestiti_'))  sezioni['Prestiti'].params.push(p);
        else if (k.startsWith('contratto_')) sezioni['Contratti'].params.push(p);
        else if (k.startsWith('stipendio_')) sezioni['Stipendi'].params.push(p);
        else if (k.startsWith('mercato_'))   sezioni['Mercato'].params.push(p);
        else if (k.startsWith('stagione_'))  sezioni['Stagione'].params.push(p);
        else if (k.startsWith('budget_'))    sezioni['Budget'].params.push(p);
        else                                 sezioni['Altro'].params.push(p);
      });
    %>

    <% Object.keys(sezioni).forEach(function(nome) {
         const sez = sezioni[nome];
         if (sez.params.length === 0) return;
    %>
    <div style="margin-bottom: 32px;">
      <h2 style="font-size: 1rem; font-weight: 800; color: var(--green-dark); margin-bottom: 14px; display: flex; align-items: center; gap: 8px;">
        <span><%= sez.icon %></span> <%= nome %>
      </h2>
      <div class="param-grid">
        <% sez.params.forEach(function(p) { %>
        <div class="param-card">
          <div class="param-key"><%= p.chiave %></div>
          <div class="param-desc"><%= p.descrizione || '—' %></div>
          <form class="param-form" action="/admin/parametri/<%= p.id %>" method="POST">
            <input type="text" name="valore" value="<%= p.valore %>" required>
            <button type="submit">💾</button>
          </form>
        </div>
        <% }); %>
      </div>
    </div>
    <% }); %>

    <% if (parametri.length === 0) { %>
    <div class="alert alert-info">Nessun parametro configurato. Esegui <code>node prisma/seed-parametri.js</code>.</div>
    <% } %>
  </div>
</body>
</html>
