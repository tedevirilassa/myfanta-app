<%/* views/admin/_tabs.ejs — barra tab condivisa per tutte le sezioni admin */%>
<style>
  .admin-tabs-wrap {
    background: #fff;
    border-bottom: 2px solid var(--gray-200);
    position: sticky; top: 0; z-index: 90;
    box-shadow: 0 2px 8px rgba(26,58,42,.06);
  }
  .admin-tabs {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 12px;
  }
  .admin-tabs::-webkit-scrollbar { display: none; }
  .admin-tab {
    display: flex; align-items: center; gap: 5px;
    padding: 11px 14px;
    font-size: .78rem; font-weight: 600;
    color: var(--gray-600);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
    transition: color .15s, border-color .15s;
    flex-shrink: 0;
  }
  .admin-tab:hover { color: var(--green-dark); border-bottom-color: var(--gray-300); }
  .admin-tab.active { color: var(--green-dark); border-bottom-color: var(--green-mid); }
</style>

<div class="admin-tabs-wrap">
  <nav class="admin-tabs" id="admin-tabs">
    <a href="/admin/contratti/nuovo"         class="admin-tab" data-path="/admin/contratti/nuovo">📝 Nuovo Contratto</a>
    <a href="/admin/sync-transfermarkt"      class="admin-tab" data-path="/admin/sync-transfermarkt">📈 Sync TM</a>
    <a href="/admin/realign-ruoli"           class="admin-tab" data-path="/admin/realign-ruoli">🎯 Riallinea Ruoli</a>
    <a href="/admin/users"                   class="admin-tab" data-path="/admin/users">👥 Utenti</a>
    <a href="/admin/situazione-finanziaria"  class="admin-tab" data-path="/admin/situazione-finanziaria">💰 Fin. Finanziaria</a>
    <a href="/admin/premi"             class="admin-tab" data-path="/admin/premi">🏅 Premi</a>
    <a href="/admin/premi/classifica"  class="admin-tab" data-path="/admin/premi/classifica">🏆 Classifica</a>
    <a href="/admin/rosa"                    class="admin-tab" data-path="/admin/rosa">📋 Rose</a>
    <a href="/admin/rinnovi"                 class="admin-tab" data-path="/admin/rinnovi">🔄 Rinnovi</a>
    <a href="/admin/svincoli-inattivi"       class="admin-tab" data-path="/admin/svincoli-inattivi">🚪 Svincoli</a>
    <a href="/admin/mercato/differiti"       class="admin-tab" data-path="/admin/mercato/differiti">📅 Differiti</a>
    <a href="/admin/fine-stagione"           class="admin-tab" data-path="/admin/fine-stagione">🗓 Fine Stagione</a>
    <a href="/admin/parametri"              class="admin-tab" data-path="/admin/parametri">⚙️ Parametri</a>
    <a href="/admin/log"                     class="admin-tab" data-path="/admin/log">📝 Log</a>
  </nav>
</div>

<script>
  (function () {
    const path = window.location.pathname;
    // Ordina per lunghezza decrescente per evitare match errati su prefissi corti
    const tabs = Array.from(document.querySelectorAll('#admin-tabs .admin-tab'))
      .sort((a, b) => b.dataset.path.length - a.dataset.path.length);
    for (const tab of tabs) {
      const p = tab.dataset.path;
      if (path === p || path.startsWith(p + '/')) {
        tab.classList.add('active');
        // Scrolla il tab attivo in vista
        tab.scrollIntoView({ inline: 'nearest', block: 'nearest' });
        break;
      }
    }
  })();
</script>
