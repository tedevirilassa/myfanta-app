<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Rose FantaTeam' }) %>
  <style>
    .rose-section {
      margin-bottom: 8px;
      border: 1.5px solid var(--gray-200);
      border-radius: 10px;
      overflow: hidden;
    }
    .rose-section summary {
      cursor: pointer;
      padding: 14px 20px;
      font-size: .95rem;
      font-weight: 800;
      color: var(--green-dark);
      display: flex;
      align-items: center;
      gap: 10px;
      background: #f8fafc;
      list-style: none;
    }
    .rose-section summary::-webkit-details-marker { display: none; }
    .rose-section summary::marker { display: none; content: ''; }
    .rose-section summary::before {
      content: '▶'; font-size: .7rem;
      transition: transform .2s; display: inline-block;
    }
    .rose-section[open] summary::before { transform: rotate(90deg); }

    .rose-body { padding: 16px 20px; }

    .rosa-mini-table { border-collapse: collapse; width: 100%; margin-bottom: 12px; }
    .rosa-mini-table th, .rosa-mini-table td {
      padding: 6px 10px; font-size: .8rem;
      border-bottom: 1px solid var(--gray-100);
    }
    .rosa-mini-table th {
      background: var(--gray-50); font-weight: 700; text-align: left;
      font-size: .72rem; text-transform: uppercase; letter-spacing: .3px; color: var(--gray-500);
    }
    .rosa-mini-table tbody tr:hover { background: #f0fdf4; }
    .rosa-mini-table td.val { text-align: right; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container">
    <div class="page-header">
      <h1>📋 Rose</h1>
      <span style="font-size:.85rem;color:var(--gray-500);">Stagione: <strong><%= stagione %></strong></span>
    </div>

    <% if (teamsData.length === 0) { %>
      <p style="color:var(--gray-400);font-style:italic;">Nessun FantaTeam configurato.</p>
    <% } else { %>
      <% teamsData.forEach(function(team) { %>
      <details class="rose-section">
        <summary>
          <span><%= team.nome %></span>
          <span style="margin-left:auto;font-size:.78rem;font-weight:600;color:var(--gray-400);"><%= team.giocatori.length %> giocatori</span>
        </summary>
        <div class="rose-body">
          <% if (team.giocatori.length === 0) { %>
            <p style="color:var(--gray-400);font-size:.82rem;font-style:italic;">Nessun giocatore con contratto valido.</p>
          <% } else { %>
          <table class="rosa-mini-table">
            <thead>
              <tr>
                <th>Giocatore</th>
                <th>Ruolo</th>
                <th style="text-align:right;">Valore (M€)</th>
              </tr>
            </thead>
            <tbody>
              <% team.giocatori.forEach(function(g) { %>
              <tr>
                <td><strong><%= g.nome %></strong></td>
                <td><%= g.ruolo %></td>
                <td class="val"><%= g.valore != null ? g.valore.toFixed(2) : '—' %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          <% } %>
          <a href="/admin/rosa/<%= team.id %>" class="btn btn-primary btn-sm" style="margin-top:4px;">
            📊 Dettaglio
          </a>
        </div>
      </details>
      <% }); %>
    <% } %>
  </div>
</body>
</html>
