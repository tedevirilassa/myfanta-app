<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Modifica profilo utente' }) %>
  <style>
    .form-group { margin-bottom: 18px; }
    .form-label {
      display: block; font-size: .82rem; font-weight: 700;
      color: var(--gray-600); margin-bottom: 6px;
      text-transform: uppercase; letter-spacing: .4px;
    }
    .form-input {
      width: 100%; padding: 10px 14px;
      border: 1px solid var(--gray-200); border-radius: 8px;
      font-size: .95rem; outline: none;
      transition: border-color .15s, box-shadow .15s;
    }
    .form-input:focus {
      border-color: var(--green-mid);
      box-shadow: 0 0 0 3px rgba(45,106,79,.15);
    }
    .form-hint { font-size: .75rem; color: var(--gray-400); margin-top: 4px; }
    .user-meta { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
    .badge-info {
      display: inline-block; padding: 2px 10px; border-radius: 12px;
      font-size: .72rem; font-weight: 700; text-transform: uppercase;
    }
    .bi-admin { background: #fef3c7; color: #92400e; }
    .bi-user  { background: #e0e7ff; color: #3730a3; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container" style="max-width: 560px;">
    <div style="margin-bottom: 16px;">
      <a href="/admin/users" style="font-size: .88rem; color: var(--green-mid); text-decoration: none;">
        ← Torna alla lista utenti
      </a>
    </div>

    <div class="page-header">
      <h1>✏️ Modifica profilo</h1>
    </div>

    <% if (success) { %>
    <div class="alert alert-success" style="margin-bottom: 20px;"><%= success %></div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-error" style="margin-bottom: 20px;"><%= error %></div>
    <% } %>

    <!-- scheda utente -->
    <div class="card" style="padding: 20px; margin-bottom: 24px;">
      <div class="user-meta">
        <div style="width:44px; height:44px; border-radius:50%; background:var(--green-mid);
                    display:flex; align-items:center; justify-content:center;
                    font-size:1.2rem; font-weight:900; color:#fff; flex-shrink:0;">
          <%= (editUser.nickname || editUser.email).charAt(0).toUpperCase() %>
        </div>
        <div>
          <div style="font-weight: 900; font-size: .95rem; color: var(--green-dark);">
            <%= editUser.email %>
          </div>
          <% if (editUser.nickname || editUser.teamName) { %>
          <div style="font-size: .82rem; color: var(--gray-500); margin-top: 2px;">
            <% if (editUser.nickname) { %>👤 <em><%= editUser.nickname %></em><% } %>
            <% if (editUser.nickname && editUser.teamName) { %>&nbsp;·&nbsp;<% } %>
            <% if (editUser.teamName) { %>🏟️ <em><%= editUser.teamName %></em><% } %>
          </div>
          <% } %>
        </div>
        <span class="badge-info <%= editUser.role === 'ADMIN' ? 'bi-admin' : 'bi-user' %>" style="margin-left:auto;">
          <%= editUser.role %>
        </span>
      </div>
    </div>

    <!-- form modifica -->
    <div class="card" style="padding: 28px;">
      <form method="POST" action="/admin/users/<%= editUser.id %>/edit-profile">
        <div class="form-group">
          <label class="form-label" for="nickname">Nickname</label>
          <input
            class="form-input"
            type="text"
            id="nickname"
            name="nickname"
            maxlength="40"
            placeholder="Es. Il Condor"
            value="<%= editUser.nickname || '' %>"
          >
          <div class="form-hint">Max 40 caratteri.</div>
        </div>

        <div class="form-group">
          <label class="form-label" for="teamName">Nome squadra</label>
          <input
            class="form-input"
            type="text"
            id="teamName"
            name="teamName"
            maxlength="60"
            placeholder="Es. Aquile del Nord FC"
            value="<%= editUser.teamName || '' %>"
          >
          <div class="form-hint">Max 60 caratteri.</div>
        </div>

        <div style="display: flex; gap: 12px;">
          <button type="submit" class="btn btn-primary" style="flex: 1; padding: 11px;">
            💾 Salva modifiche
          </button>
          <a href="/admin/users" class="btn btn-sm" style="padding: 11px 18px; align-self: stretch; display:flex; align-items:center;">
            Annulla
          </a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
