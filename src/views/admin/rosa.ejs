<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Rosa - ' + fantaTeam.nome }) %>
  <style>
    .rosa-header { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; margin-bottom: 20px; }
    .rosa-header select {
      padding: 7px 12px; border: 1.5px solid var(--gray-200);
      border-radius: 8px; font-size: .85rem; background: #fafdfa;
    }

    .rosa-stats { display: flex; gap: 16px; margin-bottom: 20px; flex-wrap: wrap; }
    .rosa-stat {
      padding: 10px 16px; border-radius: 8px; font-size: .82rem;
      background: var(--gray-50); border: 1px solid var(--gray-200);
    }
    .rosa-stat strong { display: block; font-size: 1.1rem; }
    .rosa-stat.warn { background: #fef3c7; border-color: #fde68a; }
    .rosa-stat.ok { background: #dcfce7; border-color: #bbf7d0; }

    .rosa-table { border-collapse: collapse; width: 100%; }
    .rosa-table th, .rosa-table td {
      padding: 8px 12px; font-size: .82rem;
      border-bottom: 1px solid var(--gray-200);
    }
    .rosa-table th { background: var(--gray-50); font-weight: 700; text-align: left; }
    .rosa-table tbody tr:hover { background: #f0fdf4; }
    .rosa-table td:last-child { text-align: center; }

    .rosa-table select {
      padding: 4px 8px; border: 1.5px solid var(--gray-200);
      border-radius: 6px; font-size: .8rem; background: #fff;
    }

    .badge-cat {
      display: inline-block; padding: 2px 9px; border-radius: 20px;
      font-size: .72rem; font-weight: 700;
    }
    .badge-InRosa { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
    .badge-FuoriRosa { background: #fef9c3; color: #854d0e; border: 1px solid #fde68a; }
    .badge-U21 { background: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container">
    <div class="page-header">
      <h1>📋 Rosa: <%= fantaTeam.nome %></h1>
    </div>

    <% if (message) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="rosa-header">
      <label style="font-weight:700; font-size:.85rem;">Team:</label>
      <select onchange="if(this.value) location.href='/admin/rosa/'+this.value">
        <% fantaTeams.forEach(function(ft) { %>
          <option value="<%= ft.id %>" <%= ft.id === fantaTeam.id ? 'selected' : '' %>><%= ft.nome %></option>
        <% }) %>
      </select>
      <span style="font-size:.82rem; color:var(--gray-500);">Stagione: <strong><%= stagione %></strong></span>
    </div>

    <%
      const countInRosa = giocatori.filter(g => g.categoria === 'InRosa').length;
      const countFuoriRosa = giocatori.filter(g => g.categoria === 'FuoriRosa').length;
      const countU21 = giocatori.filter(g => g.categoria === 'U21').length;
    %>
    <div class="rosa-stats">
      <div class="rosa-stat <%= countInRosa > params.maxGiocatori ? 'warn' : 'ok' %>">
        In Rosa<strong><%= countInRosa %> / <%= params.maxGiocatori %></strong>
      </div>
      <div class="rosa-stat <%= countFuoriRosa > params.maxFuoriRosa ? 'warn' : 'ok' %>">
        Fuori Rosa<strong><%= countFuoriRosa %> / <%= params.maxFuoriRosa %></strong>
      </div>
      <div class="rosa-stat <%= countU21 > params.maxU21 ? 'warn' : 'ok' %>">
        U21<strong><%= countU21 %> / <%= params.maxU21 %></strong>
      </div>
      <div class="rosa-stat">
        Totale<strong><%= giocatori.length %></strong>
      </div>
    </div>

    <% if (giocatori.length === 0) { %>
      <p style="color:var(--gray-400); font-style:italic;">Nessun giocatore con contratto valido per questo team.</p>
    <% } else { %>
    <form action="/admin/rosa/<%= fantaTeam.id %>" method="POST">
      <div class="card" style="padding:0; overflow:hidden;">
        <table class="rosa-table">
          <thead>
            <tr>
              <th>Giocatore</th>
              <th>Ruolo</th>
              <th>Squadra</th>
              <th>Età</th>
              <th>Valore</th>
              <th>Categoria</th>
            </tr>
          </thead>
          <tbody>
            <% giocatori.forEach(function(g) { %>
            <tr>
              <td><strong><%= g.nome %></strong></td>
              <td><%= g.ruolo %></td>
              <td><%= g.squadra || '—' %></td>
              <td><%= g.eta || '—' %></td>
              <td><%= g.valore ? g.valore.toFixed(2) : '—' %></td>
              <td>
                <select name="categorie[<%= g.id %>]">
                  <option value="InRosa" <%= g.categoria === 'InRosa' ? 'selected' : '' %>>In Rosa</option>
                  <option value="FuoriRosa" <%= g.categoria === 'FuoriRosa' ? 'selected' : '' %>>Fuori Rosa</option>
                  <option value="U21" <%= g.categoria === 'U21' ? 'selected' : '' %>>U21</option>
                </select>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div style="margin-top:16px;">
        <button type="submit" class="btn btn-primary">💾 Salva Rosa</button>
      </div>
    </form>
    <% } %>
  </div>
</body>
</html>
