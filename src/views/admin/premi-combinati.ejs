<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Premi' }) %>
  <style>
    .tab-bar { display:flex; gap:0; border-bottom:2px solid var(--gray-200); margin-bottom:24px; }
    .tab-btn {
      padding:10px 26px; font-size:.88rem; font-weight:700; cursor:pointer;
      border:none; background:none; border-bottom:3px solid transparent;
      color:var(--gray-500); transition:color .15s, border-color .15s;
    }
    .tab-btn.active { color:var(--green-dark); border-bottom-color:var(--green-mid); }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }

    .premi-table { width: 100%; }
    .premi-table th, .premi-table td { padding: 10px 14px; font-size: .9rem; }
    .premi-table th { background: var(--gray-100); text-align: left; font-weight: 700; color: var(--gray-700); }
    .premi-table tr:not(:last-child) td { border-bottom: 1px solid var(--gray-200); }
    .premi-input {
      width: 140px; padding: 8px 12px; border: 1.5px solid var(--gray-200);
      border-radius: 7px; font-size: .95rem; text-align: right; background: #fafdfa;
    }
    .premi-input:focus { border-color: var(--green-mid); outline: none; box-shadow: 0 0 0 2px rgba(45,106,79,.15); }
    .pres-name { font-weight: 700; color: var(--gray-700); }
    .pres-team { font-size: .78rem; color: var(--gray-400); display: block; }
    .totale-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px 20px; margin-top: 18px;
      background: #f0faf4; border-radius: 8px;
      font-size: 1rem; font-weight: 700; color: var(--green-dark);
    }
    .totale-row .totale-val { font-size: 1.3rem; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>
  <%- include('./_tabs') %>

  <div class="container" style="max-width: 820px;">
    <div class="page-header">
      <h1>🏅 Premi</h1>
    </div>

    <% if (error) { %>
      <div class="alert alert-error">❌ <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success">✔ <%= success %></div>
    <% } %>

    <div class="tab-bar">
      <button class="tab-btn" data-tab="inizio-stagione">🏁 Inizio Stagione</button>
      <button class="tab-btn" data-tab="gennaio">❄️ Gennaio</button>
    </div>

    <%
      const tipiInfo = {
        'inizio-stagione': { enum: 'InizioStagione', label: 'Premi inizio stagione', giaErogato: giaErogatoInizio },
        'gennaio':         { enum: 'Gennaio',        label: 'Premi di gennaio',      giaErogato: giaErogatoGennaio },
      };
    %>

    <% Object.entries(tipiInfo).forEach(([tipoKey, tipo]) => { %>
    <div class="tab-panel" id="panel-<%= tipoKey %>">

      <% if (tipo.giaErogato) { %>
        <div class="alert alert-error">
          ⛔ <strong><%= tipo.label %></strong> già erogati per la stagione <strong><%= stagione %></strong>
          il <%= new Date(tipo.giaErogato.createdAt).toLocaleString('it-IT') %>
          (totale: <%= Number(tipo.giaErogato.totale).toFixed(2) %> M, beneficiari: <%= tipo.giaErogato.numBenef %>).
          <br>Per ri-aggiustare i crediti usa "Aggiustamento crediti" nella Situazione Finanziaria.
        </div>
      <% } %>

      <div class="card" style="padding: 20px;">
        <p style="font-size:.85rem; color: var(--gray-700); margin-bottom: 14px;">
          Compila gli importi per i presidenti che devono ricevere il premio. Lascia vuoto (o 0) per saltare.
          Al click di <strong>Commit</strong>, gli importi vengono sommati ai crediti della situazione finanziaria
          per la stagione <strong><%= stagione %></strong>. L'operazione è atomica e si può eseguire una sola volta per stagione.
        </p>

        <form method="POST" action="/admin/premi/<%= tipoKey %>" class="form-premi" data-tipo="<%= tipoKey %>">
          <table class="premi-table">
            <thead>
              <tr>
                <th>Presidente</th>
                <th style="text-align:right; width: 200px;">Importo (M)</th>
              </tr>
            </thead>
            <tbody>
              <% presidenti.forEach(function(p) { %>
                <tr>
                  <td>
                    <span class="pres-name"><%= p.nickname || p.email %></span>
                    <% if (p.fantaTeam) { %>
                      <span class="pres-team"><%= p.fantaTeam.nome %></span>
                    <% } %>
                  </td>
                  <td style="text-align:right;">
                    <input type="number" step="0.01" min="0"
                           name="importi[<%= p.id %>]"
                           class="premi-input premio-amount"
                           data-tipo="<%= tipoKey %>"
                           placeholder="0.00"
                           <%= tipo.giaErogato ? 'disabled' : '' %>>
                  </td>
                </tr>
              <% }); %>
              <% if (presidenti.length === 0) { %>
                <tr><td colspan="2" style="text-align:center; padding: 30px; color: var(--gray-400);">
                  Nessun fantapresidente attivo con FantaTeam.
                </td></tr>
              <% } %>
            </tbody>
          </table>

          <div class="totale-row">
            <span>Totale da erogare</span>
            <span class="totale-val"><span class="totale-display" id="totale-<%= tipoKey %>">0.00</span> M</span>
          </div>

          <div style="display: flex; gap: 12px; align-items: center; margin-top: 18px;">
            <button type="submit" class="btn btn-primary"
                    <%= tipo.giaErogato || presidenti.length === 0 ? 'disabled' : '' %>>
              💾 Commit
            </button>
            <span style="font-size:.8rem; color: var(--gray-400);">
              <%= tipo.giaErogato ? 'Già erogato per questa stagione.' : 'Verrà eseguito sulla stagione ' + stagione + '.' %>
            </span>
          </div>
        </form>
      </div>
    </div>
    <% }); %>
  </div>

  <script>
    // ── Tabs ───────────────────────────────────────────────────────────────────
    const ACTIVE_TAB = '<%= activeTab %>';
    const btns   = document.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.tab-panel');

    function activateTab(tab) {
      btns.forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
      panels.forEach(p => p.classList.toggle('active', p.id === 'panel-' + tab));
    }

    btns.forEach(btn => btn.addEventListener('click', () => activateTab(btn.dataset.tab)));
    activateTab(ACTIVE_TAB);

    // ── Calcolo totali per tab ─────────────────────────────────────────────────
    document.querySelectorAll('.premio-amount').forEach(input => {
      input.addEventListener('input', () => recalc(input.dataset.tipo));
    });

    function recalc(tipoKey) {
      let tot = 0;
      document.querySelectorAll(`.premio-amount[data-tipo="${tipoKey}"]`).forEach(i => {
        const v = parseFloat(i.value);
        if (Number.isFinite(v) && v > 0) tot += v;
      });
      document.getElementById('totale-' + tipoKey).textContent =
        (Math.round(tot * 100) / 100).toFixed(2);
    }

    // ── Submit con confirm ─────────────────────────────────────────────────────
    document.querySelectorAll('.form-premi').forEach(form => {
      form.addEventListener('submit', function(e) {
        const tipoKey = this.dataset.tipo;
        let count = 0, tot = 0;
        this.querySelectorAll('.premio-amount').forEach(i => {
          const v = parseFloat(i.value);
          if (Number.isFinite(v) && v > 0) { count++; tot += v; }
        });
        if (count === 0) {
          e.preventDefault();
          alert('Nessun importo valorizzato. Inserisci almeno un valore > 0.');
          return;
        }
        const totStr = (Math.round(tot * 100) / 100).toFixed(2);
        if (!confirm(`Confermi l'erogazione a ${count} presidenti per un totale di ${totStr} M?\nL'operazione è irreversibile per questa stagione.`)) {
          e.preventDefault();
        }
      });
    });
  </script>
</body>
</html>
