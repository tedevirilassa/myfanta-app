<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Sync Transfermarkt' }) %>
  <style>
    .page-intro {
      font-size: .9rem; color: var(--gray-700); line-height: 1.6;
      margin-bottom: 24px;
    }
    /* ── Stepper ── */
    .stepper {
      display: flex; gap: 0; margin-bottom: 32px;
    }
    .step {
      flex: 1; text-align: center; padding: 10px 8px;
      font-size: .78rem; font-weight: 700; letter-spacing: .5px;
      background: var(--gray-100); color: var(--gray-400);
      border-radius: 0;
    }
    .step:first-child { border-radius: 8px 0 0 8px; }
    .step:last-child  { border-radius: 0 8px 8px 0; }
    .step.active  { background: var(--green-mid); color: #fff; }
    .step.done    { background: #d1fae5; color: var(--green-dark); }

    /* ── Log box ── */
    #log-box {
      background: #1a1a2e; color: #e2e8f0;
      border-radius: 8px; padding: 14px 16px;
      font-size: .78rem; line-height: 1.6;
      min-height: 120px; max-height: 340px;
      overflow-y: auto; font-family: monospace;
      margin-bottom: 20px;
    }
    .log-info    { color: #a7d7b8; }
    .log-success { color: #4ade80; }
    .log-warn    { color: #fbbf24; }
    .log-error   { color: #f97066; }
    .log-log     { color: #94a3b8; }

    /* ── Tabella anteprima ── */
    .preview-wrap { overflow-x: auto; margin-bottom: 24px; }
    .preview-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
    .preview-table th {
      background: var(--green-dark); color: #fff;
      padding: 8px 10px; text-align: left; white-space: nowrap;
    }
    .preview-table td { padding: 7px 10px; border-bottom: 1px solid var(--gray-200); }
    .preview-table tr:hover td { background: #f0faf4; }
    .badge-nuovo    { background: #d1fae5; color: #065f46; padding: 2px 7px; border-radius: 9px; font-size: .7rem; font-weight: 700; }
    .badge-update   { background: #e0f2fe; color: #0369a1; padding: 2px 7px; border-radius: 9px; font-size: .7rem; font-weight: 700; }
    .badge-inattivo { background: #fee2e2; color: #991b1b; padding: 2px 7px; border-radius: 9px; font-size: .7rem; font-weight: 700; }

    .filter-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; align-items: center; }
    .filter-bar select, .filter-bar input { font-size: .82rem; padding: 5px 10px; border-radius: 6px; border: 1px solid var(--gray-200); }

    .stats-bar {
      display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 20px;
    }
    .stat-chip {
      padding: 6px 14px; border-radius: 20px; font-size: .78rem; font-weight: 700;
    }
    .stat-chip.nuovi   { background: #d1fae5; color: #065f46; }
    .stat-chip.update  { background: #e0f2fe; color: #0369a1; }
    .stat-chip.inattivi{ background: #fee2e2; color: #991b1b; }
    .stat-chip.errori  { background: #fef3c7; color: #92400e; }

    .section-sep { border: none; border-top: 1px solid var(--gray-200); margin: 28px 0; }

    /* Checkbox select-all */
    .select-controls { display:flex; gap:12px; align-items:center; margin-bottom:10px; font-size:.82rem; }
    .select-controls label { cursor:pointer; }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container" style="max-width:1100px;">
    <div class="page-header">
      <h1>📈 Sync Quotazioni Transfermarkt</h1>
      <a href="/admin/pannello" class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-700);">
        ← Pannello
      </a>
    </div>

    <p class="page-intro">
      Questa pagina esegue lo scraping delle rose di Serie A da Transfermarkt.<br>
      Dopo il completamento puoi <strong>revisionare i risultati</strong> e scegliere quali giocatori importare/aggiornare prima di salvare nel database.
    </p>

    <!-- ── Stepper ── -->
    <div class="stepper">
      <div class="step active" id="step-1">1. Scraping</div>
      <div class="step" id="step-2">2. Revisione</div>
      <div class="step" id="step-3">3. Importazione</div>
    </div>

    <!-- ── FASE 1: pulsante + log ── -->
    <div id="phase-scrape">
      <div style="display:flex; gap:12px; align-items:center; margin-bottom:20px; flex-wrap:wrap;">
        <!-- Selezione squadra singola o tutte -->
        <select id="sel-squadra" style="padding:8px 12px;border-radius:8px;border:1px solid var(--gray-200);font-size:.9rem;">
          <option value="">Tutte le squadre (<%= serieATeams.length %>)</option>
          <% serieATeams.forEach(function(nome) { %>
          <option value="<%= nome %>"><%= nome %></option>
          <% }); %>
        </select>
        <button id="btn-scrape" class="btn btn-primary">▶ Avvia scraping</button>
        <span id="scrape-spinner" style="display:none;"><span class="spinner"></span> Scraping in corso… (può richiedere alcuni minuti)</span>
      </div>

      <div id="log-box"><span class="log-log">In attesa di avvio…</span></div>
    </div>

    <!-- ── FASE 2: revisione ── -->
    <div id="phase-review" style="display:none;">
      <hr class="section-sep">
      <h2 style="font-size:1rem;font-weight:700;margin-bottom:16px;">📋 Risultati scraping – revisiona e conferma</h2>

      <div class="stats-bar">
        <span class="stat-chip nuovi"    id="stat-nuovi">0 nuovi</span>
        <span class="stat-chip update"   id="stat-update">0 aggiornamenti</span>
        <span class="stat-chip inattivi" id="stat-inattivi">0 inattivi</span>
        <span class="stat-chip errori"   id="stat-errori">0 errori scraping</span>
      </div>

      <div class="filter-bar">
        <select id="filter-tipo">
          <option value="">Tutti i tipi</option>
          <option value="nuovo">Solo nuovi</option>
          <option value="update">Solo aggiornamenti</option>
          <option value="inattivo">Solo inattivi</option>
        </select>
        <select id="filter-squadra">
          <option value="">Tutte le squadre</option>
        </select>
        <input type="text" id="filter-nome" placeholder="Cerca nome…" style="flex:1;min-width:140px;">
      </div>

      <div class="select-controls">
        <label><input type="checkbox" id="chk-all" checked> Seleziona tutti visibili</label>
        <span style="color:var(--gray-400);" id="count-selected">0 selezionati</span>
      </div>

      <div class="preview-wrap">
        <table class="preview-table" id="preview-table">
          <thead>
            <tr>
              <th style="width:36px;"><input type="checkbox" id="chk-head" checked></th>
              <th>Tipo</th>
              <th>Nome</th>
              <th>Squadra</th>
              <th>Ruolo</th>
              <th>Data nasc.</th>
              <th>Età</th>
              <th>Valore (M€)</th>
              <th>TM-ID</th>
            </tr>
          </thead>
          <tbody id="preview-tbody"></tbody>
        </table>
      </div>

      <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
        <button id="btn-import" class="btn btn-primary">💾 Importa selezionati</button>
        <button id="btn-rescrape" class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-700);">
          ↺ Nuovo scraping
        </button>
        <span id="import-spinner" style="display:none;"><span class="spinner"></span> Importazione in corso…</span>
      </div>
    </div>

    <!-- ── FASE 3: risultato ── -->
    <div id="phase-done" style="display:none;">
      <hr class="section-sep">
      <div class="alert alert-success" id="done-msg"></div>
      <button id="btn-restart" class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-700);margin-top:12px;">
        ↺ Nuovo scraping
      </button>
    </div>
  </div>

  <script>
  (function () {
    // ── Refs ──────────────────────────────────────────────────────────────
    const btnScrape   = document.getElementById('btn-scrape');
    const selSquadra  = document.getElementById('sel-squadra');
    const scrSpinner  = document.getElementById('scrape-spinner');
    const logBox      = document.getElementById('log-box');
    const phScrape    = document.getElementById('phase-scrape');
    const phReview    = document.getElementById('phase-review');
    const phDone      = document.getElementById('phase-done');
    const step1       = document.getElementById('step-1');
    const step2       = document.getElementById('step-2');
    const step3       = document.getElementById('step-3');
    const tbPreview   = document.getElementById('preview-tbody');
    const filterTipo  = document.getElementById('filter-tipo');
    const filterSq    = document.getElementById('filter-squadra');
    const filterNome  = document.getElementById('filter-nome');
    const chkAll      = document.getElementById('chk-all');
    const chkHead     = document.getElementById('chk-head');
    const cntSel      = document.getElementById('count-selected');
    const btnImport   = document.getElementById('btn-import');
    const btnRescrape = document.getElementById('btn-rescrape');
    const impSpinner  = document.getElementById('import-spinner');
    const doneMsgEl   = document.getElementById('done-msg');
    const btnRestart  = document.getElementById('btn-restart');

    // Dati scraping salvati in memoria
    let scrapedData = [];

    // ── Helpers log ───────────────────────────────────────────────────────
    function logLine(msg, cls) {
      const s = document.createElement('span');
      s.className = cls || 'log-log';
      s.style.display = 'block';
      s.textContent   = msg;
      logBox.appendChild(s);
      logBox.scrollTop = logBox.scrollHeight;
    }
    function clearLog() { logBox.innerHTML = ''; }

    // ── Step helpers ──────────────────────────────────────────────────────
    function goStep(n) {
      [step1, step2, step3].forEach((el, i) => {
        el.classList.toggle('active', i + 1 === n);
        el.classList.toggle('done',   i + 1 < n);
      });
    }

    // ── FASE 1: Scraping ──────────────────────────────────────────────────
    btnScrape.addEventListener('click', async function () {
      clearLog();
      scrapedData = [];
      btnScrape.disabled = true;
      scrSpinner.style.display = 'inline';
      phReview.style.display   = 'none';
      phDone.style.display     = 'none';
      goStep(1);

      const squadraFiltro = selSquadra.value;

      try {
        const resp = await fetch('/admin/sync-transfermarkt/scrape', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ squadra: squadraFiltro || null }),
        });

        if (!resp.ok) throw new Error('HTTP ' + resp.status);

        const reader  = resp.body.getReader();
        const decoder = new TextDecoder();
        let   buf     = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop();
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            try {
              const evt = JSON.parse(line.slice(6));
              if (evt.type === 'scraped') {
                // raccoglie dati
                scrapedData = scrapedData.concat(evt.players);
                logLine(`✓ ${evt.team}: ${evt.players.length} giocatori`, 'log-success');
              } else if (evt.type === 'done') {
                logLine(`\n✅ Scraping completato. ${scrapedData.length} giocatori totali.`, 'log-info');
                showReview(evt.preview);
              } else if (evt.type === 'error') {
                logLine('✗ ' + evt.msg, 'log-error');
              } else if (evt.type === 'warn') {
                logLine(evt.msg, 'log-warn');
              } else if (evt.type === 'log') {
                logLine(evt.msg, 'log-log');
              }
            } catch { /* parse err */ }
          }
        }
      } catch (err) {
        logLine('Errore: ' + err.message, 'log-error');
      } finally {
        btnScrape.disabled       = false;
        scrSpinner.style.display = 'none';
      }
    });

    // ── FASE 2: Mostra anteprima ──────────────────────────────────────────
    function showReview(preview) {
      // preview = array di { tipo:'nuovo'|'update'|'inattivo', ...player }
      scrapedData = preview;
      goStep(2);
      phReview.style.display = 'block';

      // Aggiorna stats
      const cnt = (tipo) => preview.filter(p => p.tipo === tipo).length;
      document.getElementById('stat-nuovi').textContent    = cnt('nuovo')    + ' nuovi';
      document.getElementById('stat-update').textContent   = cnt('update')   + ' aggiornamenti';
      document.getElementById('stat-inattivi').textContent = cnt('inattivo') + ' inattivi';
      document.getElementById('stat-errori').textContent   =
        preview.filter(p => p.tipo === 'errore').length + ' errori';

      // Popola select squadre filtro
      const squadre = [...new Set(preview.map(p => p.squadra).filter(Boolean))].sort();
      filterSq.innerHTML = '<option value="">Tutte le squadre</option>';
      squadre.forEach(s => {
        const o = document.createElement('option');
        o.value = o.textContent = s;
        filterSq.appendChild(o);
      });

      renderTable(preview);
    }

    function renderTable(data) {
      tbPreview.innerHTML = '';
      data.forEach((p, idx) => {
        const tr = document.createElement('tr');
        tr.dataset.idx  = idx;
        tr.dataset.tipo = p.tipo;
        tr.dataset.sq   = p.squadra || '';
        tr.dataset.nome = (p.nome || '').toLowerCase();

        const badgeClass = p.tipo === 'nuovo' ? 'badge-nuovo' : p.tipo === 'update' ? 'badge-update' : 'badge-inattivo';
        const badgeLabel = p.tipo === 'nuovo' ? 'Nuovo' : p.tipo === 'update' ? 'Update' : 'Inattivo';

        // Inattivi non hanno checkbox (azione automatica se inclusi)
        const chkDisabled = p.tipo === 'inattivo' ? '' : '';
        tr.innerHTML = `
          <td><input type="checkbox" class="row-chk" data-idx="${idx}" ${p.tipo !== 'errore' ? 'checked' : 'disabled'}></td>
          <td><span class="${badgeClass}">${badgeLabel}</span></td>
          <td>${escHtml(p.nome || '—')}</td>
          <td>${escHtml(p.squadra || '—')}</td>
          <td>${escHtml(p.ruolo || '—')}</td>
          <td style="white-space:nowrap;">${escHtml(p.dataNascita || '—')}</td>
          <td style="text-align:center;">${p.eta != null ? p.eta : '—'}</td>
          <td style="text-align:right;">${p.valore != null ? Number(p.valore).toFixed(1) : '—'}</td>
          <td style="font-size:.72rem;color:var(--gray-400);">${escHtml(p.transfermarktId || '—')}</td>
        `;
        tbPreview.appendChild(tr);
      });
      updateSelectedCount();
      applyFilters();
    }

    function escHtml(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // ── Filtri ────────────────────────────────────────────────────────────
    function applyFilters() {
      const tipo  = filterTipo.value;
      const sq    = filterSq.value;
      const nome  = filterNome.value.toLowerCase().trim();
      tbPreview.querySelectorAll('tr').forEach(tr => {
        const show =
          (!tipo || tr.dataset.tipo === tipo) &&
          (!sq   || tr.dataset.sq   === sq)   &&
          (!nome || tr.dataset.nome.includes(nome));
        tr.style.display = show ? '' : 'none';
      });
      updateSelectedCount();
    }
    filterTipo.addEventListener('change', applyFilters);
    filterSq.addEventListener('change',   applyFilters);
    filterNome.addEventListener('input',   applyFilters);

    // ── Select all ────────────────────────────────────────────────────────
    function updateSelectedCount() {
      const all = tbPreview.querySelectorAll('.row-chk:not(:disabled)');
      const sel = tbPreview.querySelectorAll('.row-chk:not(:disabled):checked');
      cntSel.textContent = sel.length + ' / ' + all.length + ' selezionati';
    }

    [chkAll, chkHead].forEach(el => {
      el.addEventListener('change', function () {
        // seleziona solo le righe visibili
        tbPreview.querySelectorAll('tr').forEach(tr => {
          if (tr.style.display === 'none') return;
          const chk = tr.querySelector('.row-chk:not(:disabled)');
          if (chk) chk.checked = el.checked;
        });
        updateSelectedCount();
      });
    });

    tbPreview.addEventListener('change', function (e) {
      if (e.target.classList.contains('row-chk')) updateSelectedCount();
    });

    // ── Nuovo scraping ────────────────────────────────────────────────────
    [btnRescrape, btnRestart].forEach(b => b.addEventListener('click', function () {
      phReview.style.display = 'none';
      phDone.style.display   = 'none';
      goStep(1);
      clearLog();
      logLine('In attesa di avvio…', 'log-log');
    }));

    // ── FASE 3: Import ────────────────────────────────────────────────────
    btnImport.addEventListener('click', async function () {
      // Raccoglie solo gli indici selezionati
      const selected = [];
      tbPreview.querySelectorAll('.row-chk:not(:disabled):checked').forEach(chk => {
        const idx = parseInt(chk.dataset.idx, 10);
        if (!isNaN(idx) && scrapedData[idx]) selected.push(scrapedData[idx]);
      });

      if (selected.length === 0) {
        alert('Nessun giocatore selezionato.');
        return;
      }

      btnImport.disabled       = true;
      impSpinner.style.display = 'inline';

      try {
        const resp = await fetch('/admin/sync-transfermarkt/import', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ players: selected }),
        });
        const data = await resp.json();
        if (!resp.ok) throw new Error(data.error || 'HTTP ' + resp.status);

        goStep(3);
        phDone.style.display = 'block';
        phReview.style.display = 'none';
        doneMsgEl.innerHTML =
          `✅ Importazione completata — ` +
          `<strong>${data.nuovi}</strong> nuovi, ` +
          `<strong>${data.aggiornati}</strong> aggiornati, ` +
          `<strong>${data.inattivi}</strong> inattivati, ` +
          `<strong>${data.quotazioni}</strong> quotazioni salvate.`;
      } catch (err) {
        alert('Errore importazione: ' + err.message);
      } finally {
        btnImport.disabled       = false;
        impSpinner.style.display = 'none';
      }
    });
  })();
  </script>
</body>
</html>
