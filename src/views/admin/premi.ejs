<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: tipo.label }) %>
  <style>
    .premi-table { width: 100%; }
    .premi-table th, .premi-table td { padding: 10px 14px; font-size: .9rem; }
    .premi-table th { background: var(--gray-100); text-align: left; font-weight: 700; color: var(--gray-700); }
    .premi-table tr:not(:last-child) td { border-bottom: 1px solid var(--gray-200); }
    .premi-input {
      width: 140px; padding: 8px 12px; border: 1.5px solid var(--gray-200);
      border-radius: 7px; font-size: .95rem; text-align: right; background: #fafdfa;
    }
    .premi-input:focus { border-color: var(--green-mid); outline: none; box-shadow: 0 0 0 2px rgba(45,106,79,.15); }
    .pres-name { font-weight: 700; color: var(--gray-700); }
    .pres-team { font-size: .78rem; color: var(--gray-400); display: block; }
    .totale-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px 20px; margin-top: 18px;
      background: #f0faf4; border-radius: 8px;
      font-size: 1rem; font-weight: 700; color: var(--green-dark);
    }
    .totale-row .totale-val { font-size: 1.3rem; }
    .stagione-pill {
      display: inline-block; padding: 4px 10px; background: var(--gray-100);
      border-radius: 12px; font-size: .8rem; font-weight: 700; color: var(--gray-700);
      margin-left: 10px;
    }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container" style="max-width: 820px;">
    <div class="page-header">
      <h1><%= tipo.icona %> <%= tipo.label %><span class="stagione-pill">Stagione <%= stagione %></span></h1>
      <a href="/admin/pannello" class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-700);">← Pannello</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error">❌ <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success">✔ Premi erogati con successo. Crediti e patrimoni aggiornati.</div>
    <% } %>

    <% if (giaErogato) { %>
      <div class="alert alert-error">
        ⛔ <strong><%= tipo.label %></strong> già erogati per la stagione <strong><%= stagione %></strong>
        il <%= new Date(giaErogato.createdAt).toLocaleString('it-IT') %>
        (totale: <%= Number(giaErogato.totale).toFixed(2) %>, beneficiari: <%= giaErogato.numBenef %>).
        <br>Per ri-aggiustare i crediti usa "Aggiustamento crediti" nella Situazione Finanziaria.
      </div>
    <% } %>

    <div class="card" style="padding: 20px;">
      <p style="font-size:.85rem; color: var(--gray-700); margin-bottom: 14px;">
        Compila gli importi per i presidenti che devono ricevere il premio. Lascia vuoto (o 0) per saltare.
        Al click di <strong>Commit</strong>, gli importi vengono sommati ai crediti della situazione finanziaria
        per la stagione <strong><%= stagione %></strong>. L'operazione è atomica e si può eseguire una sola volta per stagione.
      </p>

      <form method="POST" action="/admin/premi/<%= tipoKey %>" id="form-premi">
        <table class="premi-table">
          <thead>
            <tr>
              <th>Presidente</th>
              <th style="text-align:right; width: 200px;">Importo (M)</th>
            </tr>
          </thead>
          <tbody>
            <% presidenti.forEach(function(p) { %>
              <tr>
                <td>
                  <span class="pres-name"><%= p.nickname || p.email %></span>
                  <% if (p.fantaTeam) { %>
                    <span class="pres-team"><%= p.fantaTeam.nome %></span>
                  <% } %>
                </td>
                <td style="text-align:right;">
                  <input type="number" step="0.01" min="0"
                         name="importi[<%= p.id %>]"
                         class="premi-input premio-amount"
                         placeholder="0.00"
                         <%= giaErogato ? 'disabled' : '' %>>
                </td>
              </tr>
            <% }); %>
            <% if (presidenti.length === 0) { %>
              <tr><td colspan="2" style="text-align:center; padding: 30px; color: var(--gray-400);">
                Nessun fantapresidente attivo con FantaTeam.
              </td></tr>
            <% } %>
          </tbody>
        </table>

        <div class="totale-row">
          <span>Totale da erogare</span>
          <span class="totale-val"><span id="totale">0.00</span> M</span>
        </div>

        <div style="display: flex; gap: 12px; align-items: center; margin-top: 18px;">
          <button type="submit" class="btn btn-primary"
                  <%= giaErogato || presidenti.length === 0 ? 'disabled' : '' %>>
            💾 Commit
          </button>
          <span id="commit-hint" style="font-size:.8rem; color: var(--gray-400);">
            <%= giaErogato ? 'Già erogato per questa stagione.' : 'Verrà eseguito sulla stagione ' + stagione + '.' %>
          </span>
        </div>
      </form>
    </div>
  </div>

  <script>
    (function () {
      const inputs = document.querySelectorAll(".premio-amount");
      const totaleEl = document.getElementById("totale");
      const form = document.getElementById("form-premi");

      function recalcTotale() {
        let tot = 0;
        inputs.forEach(i => {
          const v = parseFloat(i.value);
          if (Number.isFinite(v) && v > 0) tot += v;
        });
        totaleEl.textContent = (Math.round(tot * 100) / 100).toFixed(2);
      }
      inputs.forEach(i => i.addEventListener("input", recalcTotale));
      recalcTotale();

      if (form) {
        form.addEventListener("submit", function (e) {
          let count = 0;
          inputs.forEach(i => {
            const v = parseFloat(i.value);
            if (Number.isFinite(v) && v > 0) count++;
          });
          if (count === 0) {
            e.preventDefault();
            alert("Nessun importo valorizzato. Inserisci almeno un valore > 0.");
            return;
          }
          if (!confirm("Confermi l'erogazione a " + count + " presidenti per un totale di " + totaleEl.textContent + " M? L'operazione è irreversibile per questa stagione.")) {
            e.preventDefault();
          }
        });
      }
    })();
  </script>
</body>
</html>
