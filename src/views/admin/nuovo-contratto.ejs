<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Nuovo Contratto' }) %>
  <style>
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px 28px;
    }
    @media (max-width: 640px) { .form-grid { grid-template-columns: 1fr; } }
    .form-grid .span-2 { grid-column: 1 / -1; }

    /* valore calcolato in sola lettura */
    .readonly-field {
      width: 100%; padding: 10px 14px;
      border: 1.5px solid var(--gray-200);
      border-radius: 7px; font-size: 1rem;
      background: #f0faf4; color: var(--gray-700);
      cursor: default;
    }

    /* select giocatore con ricerca */
    .select-hint { font-size: .75rem; color: var(--gray-400); margin-top: 4px; }

    /* highlight campo obbligatorio */
    .required-mark { color: var(--red); margin-left: 2px; }

    .form-footer {
      display: flex; gap: 12px; align-items: center;
      padding-top: 20px; margin-top: 8px;
      border-top: 1px solid var(--gray-200);
    }

    .filtro-btn.active {
      outline: 2px solid var(--gray-600);
      font-weight: 600;
    }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container" style="max-width: 780px;">
    <div class="page-header">
      <h1>📝 Nuovo Contratto</h1>
      <a href="/admin/pannello" class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-700);">
        ← Pannello
      </a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error">❌ <%= error %></div>
    <% } %>

    <div class="card">
      <form action="/admin/contratti/nuovo" method="POST" id="form-contratto">
        <div class="form-grid">

          <!-- ── TIPO ────────────────────────────────────── -->
          <div class="form-group">
            <label for="tipo">Tipo <span class="required-mark">*</span></label>
            <select id="tipo" name="tipo" required>
              <option value="">— Scegli —</option>
              <option value="Acquisto">Acquisto</option>
              <option value="Cessione">Cessione</option>
              <option value="Prestito">Prestito</option>
            </select>
          </div>

          <!-- ── CLAUSOLA ───────────────────────────────── -->
          <div class="form-group">
            <label for="clausola">Clausola</label>
            <select id="clausola" name="clausola">
              <option value="">— Nessuna —</option>
              <option value="DirittoRiscatto">Diritto di riscatto</option>
              <option value="DirittoRicompra">Diritto di ricompra</option>
              <option value="ObbligoRiscatto">Obbligo di riscatto</option>
              <option value="ObbligoRicompra">Obbligo di ricompra</option>
            </select>
          </div>

          <!-- ── GIOCATORE ──────────────────────────────── -->
          <div class="form-group span-2">
            <label for="giocatoreId">Giocatore <span class="required-mark">*</span></label>

            <!-- Filtro disponibilità -->
            <div style="display:flex; gap:8px; margin-bottom:8px;" id="filtro-giocatore-wrap">
              <button type="button" class="btn btn-sm filtro-btn active" data-filtro="tutti"
                style="background:var(--gray-200);color:var(--gray-700);">Tutti</button>
              <button type="button" class="btn btn-sm filtro-btn" data-filtro="liberi"
                style="background:#e8f5e9;color:#2e7d32;">🟢 Liberi</button>
              <button type="button" class="btn btn-sm filtro-btn" data-filtro="contratto"
                style="background:#fff3e0;color:#e65100;">🟠 Con contratto</button>
            </div>

            <select id="giocatoreId" name="giocatoreId" required>
              <option value="">— Seleziona giocatore —</option>
              <% giocatori.forEach(function(g) { %>
                <option
                  value="<%= g.id %>"
                  data-valore="<%= g.valore !== null ? Number(g.valore) : '' %>"
                  data-has-contratto="<%= g.hasContratto ? '1' : '0' %>"
                  data-titolare="<%= g.titolareContratto || '' %>"
                >
                  [<%= g.ruolo %>] <%= g.nome %><%= g.squadra ? ' – ' + g.squadra : '' %><%= g.hasContratto ? ' ⚠️' : '' %>
                </option>
              <% }); %>
            </select>
            <div class="select-hint" id="hint-giocatore-count"></div>
          </div>

          <!-- ── VALORE GIOCATORE (auto-fill) ──────────── -->
          <div class="form-group span-2">
            <label>Valore giocatore alla stipula (€)</label>
            <div class="readonly-field" id="valore-display">— seleziona prima un giocatore —</div>
            <input type="hidden" id="valoreGiocatore" name="valoreGiocatore">
          </div>

          <!-- ── FANTAPRESIDENTE ────────────────────────── -->
          <div class="form-group span-2">
            <label for="fantaPresidenteId">Fantapresidente <span class="required-mark">*</span></label>
            <select id="fantaPresidenteId" name="fantaPresidenteId" required>
              <option value="">— Seleziona presidente —</option>
              <% presidenti.forEach(function(p) { %>
                <option value="<%= p.id %>">
                  <%= p.nickname ? p.nickname + ' (' + p.email + ')' : p.email %>
                  <% if (p.fantaTeam && p.fantaTeam.nome) { %> – <%= p.fantaTeam.nome %><% } %>
                </option>
              <% }); %>
            </select>
          </div>

          <!-- ── DATA STIPULA ───────────────────────────── -->
          <div class="form-group">
            <label for="dataStipula">Data stipula (MM-YYYY) <span class="required-mark">*</span></label>
            <input type="text" id="dataStipula" name="dataStipula"
                   placeholder="es. 01-2026" pattern="\d{2}-\d{4}"
                   title="Formato MM-YYYY" required>
          </div>

          <!-- ── DURATA ─────────────────────────────────── -->
          <div class="form-group">
            <label for="durataContratto">Durata (anni) <span class="required-mark">*</span></label>
            <select id="durataContratto" name="durataContratto" required>
              <option value="">— Scegli —</option>
              <% const dMin = (parametri && parametri.contratto_durata_min) || 1;
                 const dMax = (parametri && parametri.contratto_durata_max) || 3;
                 for (let d = dMin; d <= dMax; d++) { %>
              <option value="<%= d %>"><%= d %> ann<%= d === 1 ? 'o' : 'i' %></option>
              <% } %>
            </select>
          </div>

          <!-- ── DATA FINE (auto-calcolata) ────────────── -->
          <div class="form-group">
            <label>Data fine (MM-YYYY)</label>
            <div class="readonly-field" id="dataFine-display">— si calcola automaticamente —</div>
            <input type="hidden" id="dataFine" name="dataFine">
          </div>

          <!-- ── IMPORTO OPERAZIONE / STIPENDIO ─────────── -->
          <div class="form-group">
            <label for="importoOperazione" id="lbl-importo">Importo operazione (€)</label>
            <input type="number" id="importoOperazione" name="importoOperazione"
                   min="0" step="0.01" placeholder="es. 25.5">
            <div class="select-hint" id="hint-importo"></div>
          </div>

          <!-- ── PREZZO ACQUISTO ────────────────────────── -->
          <div class="form-group" id="grp-prezzo" style="display:none;">
            <label for="prezzoAcquisto">Prezzo acquisto (M) <span class="required-mark">*</span></label>
            <input type="number" id="prezzoAcquisto" name="prezzoAcquisto"
                   min="0" step="0.01" placeholder="Costo per il compratore">
            <div class="select-hint" id="hint-prezzo">Importo che verrà scalato dai crediti dell'acquirente</div>
          </div>

          <!-- ── PROVENIENZA ────────────────────────────── -->
          <div class="form-group span-2">
            <label for="provenienza">Provenienza</label>
            <input type="text" id="provenienza" name="provenienza"
                   placeholder="es. Pubblico, Privato, nome presidente…">
            <div class="select-hint" id="hint-mercato"></div>
          </div>

        </div><!-- /form-grid -->

        <div class="form-footer">
          <button type="submit" class="btn btn-primary">💾 Salva contratto</button>
          <a href="/admin/pannello" class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-700);">
            Annulla
          </a>
        </div>
      </form>
    </div>
  </div>

  <script>
    (function () {
      const selGiocatore = document.getElementById("giocatoreId");
      const valoreDisplay = document.getElementById("valore-display");
      const valoreInput = document.getElementById("valoreGiocatore");
      const selTipo = document.getElementById("tipo");

      // ── Filtro giocatori ───────────────────────────────────
      const allOptions = Array.from(selGiocatore.options).filter(o => o.value !== "");
      const hintCount = document.getElementById("hint-giocatore-count");

      function applyFiltroGiocatori(filtro) {
        const currentVal = selGiocatore.value;
        selGiocatore.innerHTML = '<option value="">— Seleziona giocatore —</option>';
        let count = 0;
        allOptions.forEach(function(opt) {
          const hasC = opt.dataset.hasContratto === "1";
          if (filtro === "liberi" && hasC) return;
          if (filtro === "contratto" && !hasC) return;
          selGiocatore.appendChild(opt);
          count++;
        });
        // Ripristina selezione se ancora visibile
        if (currentVal && selGiocatore.querySelector('option[value="' + currentVal + '"]')) {
          selGiocatore.value = currentVal;
        } else {
          selGiocatore.value = "";
          valoreDisplay.textContent = "— seleziona prima un giocatore —";
          valoreInput.value = "";
        }
        const label = filtro === "liberi" ? "liberi" : filtro === "contratto" ? "con contratto attivo" : "totali";
        hintCount.textContent = count + " giocatori " + label;
      }

      document.querySelectorAll(".filtro-btn").forEach(function(btn) {
        btn.addEventListener("click", function() {
          document.querySelectorAll(".filtro-btn").forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          applyFiltroGiocatori(btn.dataset.filtro);
        });
      });

      // Inizializza contatore
      applyFiltroGiocatori("tutti");
      const inputImporto = document.getElementById("importoOperazione");
      const lblImporto = document.getElementById("lbl-importo");
      const hintImporto = document.getElementById("hint-importo");
      const grpPrezzo = document.getElementById("grp-prezzo");
      const inputPrezzo = document.getElementById("prezzoAcquisto");
      const selDurata = document.getElementById("durataContratto");
      const inputStipula = document.getElementById("dataStipula");
      const dataFineDisplay = document.getElementById("dataFine-display");
      const dataFineInput = document.getElementById("dataFine");

      // ── Parametri mercato invernale ────────────────────────
      const STIPENDIO_PCT = parseFloat("<%= (parametri && parametri.stipendio_percentuale) || '0.10' %>");
      const STIPENDIO_PCT_INV = parseFloat("<%= (parametri && parametri.stipendio_percentuale_invernale) || '0.05' %>");
      const MERCATO_INV_INIZIO = "<%= (parametri && parametri.mercato_invernale_inizio) || '01-01' %>"; // GG-MM
      const MERCATO_INV_FINE = "<%= (parametri && parametri.mercato_invernale_fine) || '15-02' %>"; // GG-MM

      function isSessioneInvernale(stipula) {
        if (!stipula || !/^\d{2}-\d{4}$/.test(stipula)) return false;
        const mm = parseInt(stipula.split("-")[0], 10);
        const invIzMM = parseInt(MERCATO_INV_INIZIO.split("-")[1], 10);
        const invFinMM = parseInt(MERCATO_INV_FINE.split("-")[1], 10);
        return mm >= invIzMM && mm <= invFinMM;
      }

      function calcStipendio() {
        if (selTipo.value !== "Acquisto") return;
        const valore = parseFloat(valoreInput.value);
        const stipula = inputStipula.value.trim();
        if (!valore || isNaN(valore)) {
          hintImporto.textContent = "Seleziona un giocatore per calcolare lo stipendio";
          return;
        }
        const invernale = isSessioneInvernale(stipula);
        const pct = invernale ? STIPENDIO_PCT_INV : STIPENDIO_PCT;
        const stip = Math.round(valore * pct * 100) / 100;
        inputImporto.value = stip.toFixed(2);
        hintImporto.textContent = invernale
          ? "Sessione invernale: " + (pct * 100).toFixed(0) + "% di " + valore.toFixed(1) + " = " + stip.toFixed(2) + " M"
          : "Sessione estiva: " + (pct * 100).toFixed(0) + "% di " + valore.toFixed(1) + " = " + stip.toFixed(2) + " M";
      }

      // ── Aggiorna label/range importo in base al tipo ───────
      selTipo.addEventListener("change", updateImportoLabel);
      function updateImportoLabel() {
        if (selTipo.value === "Prestito") {
          lblImporto.innerHTML = 'Corrispettivo prestito (M) <span class="required-mark">*</span>';
          inputImporto.min = "0.1";
          inputImporto.max = "5";
          inputImporto.step = "0.1";
          inputImporto.placeholder = "da 0.1 a 5";
          inputImporto.required = true;
          hintImporto.textContent = "Importo dal prestante al presidente che riceve il giocatore (0.1 – 5 M)";
          grpPrezzo.style.display = "none";
          inputPrezzo.required = false;
        } else if (selTipo.value === "Acquisto") {
          lblImporto.innerHTML = 'Stipendio (M) <span class="required-mark">*</span>';
          inputImporto.min = "0";
          inputImporto.removeAttribute("max");
          inputImporto.step = "0.01";
          inputImporto.placeholder = "auto-calcolato";
          inputImporto.required = true;
          hintImporto.textContent = "Calcolato automaticamente in base alla sessione di mercato";
          calcStipendio();
          grpPrezzo.style.display = "";
          inputPrezzo.required = true;
        } else {
          lblImporto.textContent = "Importo operazione (€)";
          inputImporto.min = "0";
          inputImporto.removeAttribute("max");
          inputImporto.step = "0.01";
          inputImporto.placeholder = "es. 25.5";
          inputImporto.required = false;
          hintImporto.textContent = "";
          grpPrezzo.style.display = "none";
          inputPrezzo.required = false;
        }
      }
      updateImportoLabel();

      // Trigger calcStipendio on giocatore/data changes
      selGiocatore.addEventListener("change", function () {
        calcStipendio();
      });
      inputStipula.addEventListener("input", calcStipendio);

      // ── Gestione Prestito: durata fissa 1 stagione ─────────
      selTipo.addEventListener("change", updateDurataPrestito);
      function updateDurataPrestito() {
        if (selTipo.value === "Prestito") {
          selDurata.value = "1";
          selDurata.style.pointerEvents = "none";
          selDurata.style.opacity = "0.6";
        } else {
          selDurata.style.pointerEvents = "";
          selDurata.style.opacity = "";
        }
        calcDataFine();
      }
      updateDurataPrestito();

      const inputProvenienza = document.getElementById("provenienza");

      // ── Aggiorna valore giocatore + auto-provenienza ───────
      selGiocatore.addEventListener("change", function () {
        const opt = selGiocatore.options[selGiocatore.selectedIndex];
        const val = opt ? opt.dataset.valore : "";
        if (val !== "") {
          const num = parseFloat(val);
          valoreDisplay.textContent = num.toLocaleString("it-IT", {
            minimumFractionDigits: 2, maximumFractionDigits: 2
          }) + " €";
          valoreInput.value = num;
        } else {
          valoreDisplay.textContent = "— seleziona prima un giocatore —";
          valoreInput.value = "";
        }
        // Auto-popola provenienza col nome del titolare
        const titolare = opt ? (opt.dataset.titolare || "") : "";
        if (titolare) {
          inputProvenienza.value = titolare;
          inputProvenienza.style.background = "#fff8e1";
        } else {
          inputProvenienza.value = "";
          inputProvenienza.style.background = "";
        }
      });

      const hintMercato = document.getElementById("hint-mercato");

      // ── Parametri finestre di mercato ──────────────────────
      const MERCATO_ESTIVO_IZ = parseInt("<%= (parametri && parametri.mercato_estivo_inizio) || '01-07' %>".split("-")[1], 10);
      const MERCATO_ESTIVO_FIN = parseInt("<%= (parametri && parametri.mercato_estivo_fine) || '15-09' %>".split("-")[1], 10);
      const MERCATO_INV_IZ_M = parseInt(MERCATO_INV_INIZIO.split("-")[1], 10);
      const MERCATO_INV_FIN_M = parseInt(MERCATO_INV_FINE.split("-")[1], 10);
      const MERCATO_PRIV_IZ = parseInt("<%= (parametri && parametri.mercato_privato_inizio) || '01-07' %>".split("-")[1], 10);
      const MERCATO_PRIV_FIN = parseInt("<%= (parametri && parametri.mercato_privato_fine) || '15-02' %>".split("-")[1], 10);

      // ── Parametri stagione ─────────────────────────────────
      const STAGIONE_INIZIO = "<%= (parametri && parametri.stagione_inizio) || '01-07' %>"; // GG-MM
      const MESE_INIZIO_STAGIONE = parseInt(STAGIONE_INIZIO.split("-")[1], 10) || 7;

      // ── Calcola data fine ──────────────────────────────────
      // Stagione parametrizzata
      // Prestito: scade a inizio prossima stagione
      // Acquisto/Cessione mercato PUBBLICO: fine = mese stagione
      // Mercato PRIVATO o non specificato: fine = stesso mese, anno + durata
      function calcDataFine() {
        const stipula     = inputStipula.value.trim();   // MM-YYYY
        const tipo        = selTipo.value;
        const durata      = parseInt(selDurata.value, 10);
        const provenienza = inputProvenienza.value.trim();

        if (!stipula || !/^\d{2}-\d{4}$/.test(stipula) || !durata) {
          dataFineDisplay.textContent = "— si calcola automaticamente —";
          dataFineInput.value = "";
          return;
        }
        const [mm, yyyy] = stipula.split("-").map(Number);
        if (!mm || mm < 1 || mm > 12 || !yyyy) {
          dataFineDisplay.textContent = "— data stipula non valida —";
          dataFineInput.value = "";
          return;
        }

        let fineStr;
        if (tipo === "Prestito") {
          // Prestito: scade a inizio prossima stagione
          const mesePad = String(MESE_INIZIO_STAGIONE).padStart(2, "0");
          fineStr = mm >= MESE_INIZIO_STAGIONE ? mesePad + "-" + (yyyy + 1) : mesePad + "-" + yyyy;
        } else if (provenienza === "Pubblico") {
          const mesePad = String(MESE_INIZIO_STAGIONE).padStart(2, "0");
          const fineAnno = (mm === MESE_INIZIO_STAGIONE)
            ? yyyy + durata
            : yyyy + durata - 1;
          fineStr = mesePad + "-" + fineAnno;
        } else {
          fineStr = String(mm).padStart(2, "0") + "-" + (yyyy + durata);
        }
        }

        dataFineDisplay.textContent = fineStr;
        dataFineInput.value = fineStr;
      }

      inputStipula.addEventListener("input", calcDataFine);
      selDurata.addEventListener("change", calcDataFine);
      inputProvenienza.addEventListener("input", calcDataFine);
      selTipo.addEventListener("change", calcDataFine);
    })();
  </script>
</body>
</html>
