<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Gestione utenti' }) %>
  <style>
    details.edit-user summary {
      cursor: pointer; font-size: .78rem; font-weight: 700;
      color: var(--green-dark); list-style: none; padding: 3px 8px;
      border: 1.5px solid var(--green-light); border-radius: 6px;
      display: inline-block;
    }
    details.edit-user summary::-webkit-details-marker { display: none; }
    details.edit-user[open] summary { background: var(--green-light); }
    .edit-user-form {
      margin-top: 10px; padding: 12px 14px; background: #f0fdf4;
      border: 1px solid var(--green-light); border-radius: 8px;
      display: flex; flex-direction: column; gap: 8px; min-width: 220px;
    }
    .edit-user-form label { font-size: .75rem; font-weight: 700; color: var(--gray-500); }
    .edit-user-form input, .edit-user-form select {
      width: 100%; padding: 5px 8px; border: 1.5px solid var(--gray-200);
      border-radius: 6px; font-size: .82rem; background: #fff;
    }
    .edit-user-form .btn-save {
      padding: 5px 14px; font-size: .8rem; font-weight: 700;
      background: var(--green-mid); color: #fff;
      border: none; border-radius: 6px; cursor: pointer; align-self: flex-start;
    }
    .edit-user-form .btn-save:hover { background: var(--green-dark); }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container">
    <div class="page-header">
      <h1>Gestione utenti</h1>
      <a href="/admin/users/invite" class="btn btn-primary">+ Invita utente</a>
    </div>

    <% if (message) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>
    <% if (roleError === 'self') { %>
      <div class="alert alert-error">Non puoi modificare il tuo ruolo.</div>
    <% } %>
    <% if (roleError === 'invalid') { %>
      <div class="alert alert-error">Ruolo non valido.</div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="card" style="padding:0; overflow:hidden;">
      <div style="overflow-x:auto;">
      <table style="min-width:900px;">
        <thead>
          <tr>
            <th>Email</th>
            <th>Nickname</th>
            <th>FantaTeam</th>
            <th>Ruolo</th>
            <th>Stato</th>
            <th>Cambio pwd</th>
            <th>Creato il</th>
            <th>Azioni</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(u) { %>
          <tr>
            <td>
              <details class="edit-user">
                <summary>✏️ <%= u.email %></summary>
                <form action="/admin/users/<%= u.id %>/save-fields" method="POST" class="edit-user-form">
                  <div>
                    <label>Email</label>
                    <input type="email" name="email" value="<%= u.email %>" required>
                  </div>
                  <div>
                    <label>Nickname</label>
                    <input type="text" name="nickname" value="<%= u.nickname || '' %>" maxlength="40" placeholder="—">
                  </div>
                  <div>
                    <label>FantaTeam</label>
                    <select name="fantaTeamId">
                      <option value="">— nessuno —</option>
                      <% tuttiTeam.forEach(function(ft) { %>
                        <option value="<%= ft.id %>"
                          <%= u.fantaTeam && u.fantaTeam.id === ft.id ? 'selected' : '' %>
                          <%= !ft.userId || ft.userId === u.id ? '' : 'style="color:#b91c1c;"' %>>
                          <%= ft.nome %><%= ft.userId && ft.userId !== u.id ? ' (occupato)' : '' %>
                        </option>
                      <% }) %>
                    </select>
                  </div>
                  <button type="submit" class="btn-save">💾 Salva</button>
                </form>
              </details>
            </td>
            <td style="font-size:.85rem;">
              <%= u.nickname || '<span style="color:#cbd5e1;font-style:italic;">—</span>' %>
            </td>
            <td style="font-size:.85rem;">
              <% if (u.fantaTeam) { %>
                <span style="font-weight:700; color:var(--green-dark);"><%= u.fantaTeam.nome %></span>
              <% } else { %>
                <span style="color:#cbd5e1; font-style:italic;">—</span>
              <% } %>
            </td>
            <td>
              <span class="badge <%= u.role === 'ADMIN' ? 'badge-admin' : u.role === 'POWER_USER' ? 'badge-poweruser' : 'badge-user' %>">
                <%= u.role === 'POWER_USER' ? 'Power User' : u.role %>
              </span>
            </td>
            <td>
              <span class="badge <%= u.isActive ? 'badge-active' : 'badge-inactive' %>">
                <%= u.isActive ? 'Attivo' : 'Disabilitato' %>
              </span>
            </td>
            <td style="font-size:.82rem; color:<%= u.mustChangePassword ? '#b45309' : '#64748b' %>;">
              <%= u.mustChangePassword ? 'Richiesto' : 'No' %>
            </td>
            <td style="font-size:.82rem; color:#64748b;">
              <%= u.createdAt.toLocaleDateString('it-IT') %>
            </td>
            <td>
              <div class="actions">
                <% if (u.id !== currentUser.id) { %>
                <!-- Reimposta password -->
                <form action="/admin/users/<%= u.id %>/reset-password" method="POST"
                      onsubmit="return confirm('Reimpostare la password di <%= u.email %>?')">
                  <button type="submit" class="btn btn-warning btn-sm">Reset pwd</button>
                </form>

                <!-- Cambio ruolo -->
                <form action="/admin/users/<%= u.id %>/change-role" method="POST" style="display:flex; gap:4px; align-items:center;">
                  <select name="role" style="font-size:.8rem; padding:2px 6px; border-radius:4px; border:1px solid #cbd5e1;">
                    <option value="USER"       <%= u.role === 'USER'       ? 'selected' : '' %>>User</option>
                    <option value="POWER_USER" <%= u.role === 'POWER_USER' ? 'selected' : '' %>>Power User</option>
                    <option value="ADMIN"      <%= u.role === 'ADMIN'      ? 'selected' : '' %>>Admin</option>
                  </select>
                  <button type="submit" class="btn btn-sm btn-primary">Salva</button>
                </form>

                <!-- Abilita / Disabilita -->
                <form action="/admin/users/<%= u.id %>/toggle" method="POST"
                      onsubmit="return confirm('<%= u.isActive ? 'Disabilitare' : 'Abilitare' %> <%= u.email %>?')">
                  <button type="submit" class="btn btn-sm <%= u.isActive ? 'btn-danger' : 'btn-success' %>">
                    <%= u.isActive ? 'Disabilita' : 'Abilita' %>
                  </button>
                </form>
                <% } else { %>
                  <span style="font-size:.8rem; color:#94a3b8;">(tu)</span>
                <% } %>
              </div>
            </td>
          </tr>
          <% }); %>
          <% if (users.length === 0) { %>
          <tr>
            <td colspan="8" style="text-align:center; color:#94a3b8; padding:32px;">
              Nessun utente trovato.
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
      </div>
    </div><!-- /card utenti -->

    <% if (teamLiberi && teamLiberi.length > 0) { %>
    <div class="card" style="margin-top:28px;">
      <h2 style="font-size:1rem; font-weight:800; color:var(--green-dark); margin-bottom:16px;">
        ⚽ FantaTeam senza presidente
      </h2>
      <p style="font-size:.85rem; color:#64748b; margin-bottom:20px;">
        Associa un FantaTeam già censito a un presidente (può essere anche un utente che non ha ancora accettato l'invito).
      </p>
      <div style="display:flex; flex-direction:column; gap:12px;">
        <% teamLiberi.forEach(function(t) { %>
        <form action="/admin/fanta-teams/<%= t.id %>/assign" method="POST"
              style="display:flex; flex-wrap:wrap; align-items:center; gap:10px; padding:12px 16px; background:#f8fafc; border-radius:8px; border:1px solid var(--gray-200);">
          <span style="font-weight:700; color:var(--green-dark); min-width:200px;">🏆 <%= t.nome %></span>
          <select name="userId" required style="flex:1; min-width:200px; padding:7px 10px; border-radius:6px; border:1.5px solid var(--gray-200); font-size:.85rem;">
            <option value="" disabled selected>— Seleziona presidente —</option>
            <% users.forEach(function(u) { %>
              <% if (!u.fantaTeam) { %>
              <option value="<%= u.id %>">
                <%= u.nickname || u.email %><% if (u.teamName) { %> (<%= u.teamName %>)<% } %>
              </option>
              <% } %>
            <% }); %>
          </select>
          <button type="submit" class="btn btn-primary btn-sm">Assegna</button>
        </form>
        <% }); %>
      </div>
    </div>
    <% } %>

  </div><!-- /container -->
</body>
</html>
