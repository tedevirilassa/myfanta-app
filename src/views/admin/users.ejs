<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { title: 'Gestione utenti' }) %>
  <style>
    .user-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 16px;
    }
    .user-card {
      background: #fff; border: 1.5px solid var(--gray-200); border-radius: 12px;
      padding: 16px 20px; position: relative;
      transition: box-shadow .15s;
    }
    .user-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.06); }
    .user-card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
    .user-card-email { font-weight: 700; font-size: .9rem; color: var(--green-dark); word-break: break-all; }
    .user-card-meta { display: grid; grid-template-columns: auto 1fr; gap: 4px 12px; font-size: .82rem; }
    .user-card-meta dt { color: var(--gray-400); font-weight: 600; }
    .user-card-meta dd { margin: 0; color: var(--gray-700); }
    .user-card-actions { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--gray-100); }

    details.edit-user { margin-top: 12px; }
    details.edit-user summary {
      cursor: pointer; font-size: .78rem; font-weight: 700;
      color: var(--green-dark); list-style: none; padding: 3px 8px;
      border: 1.5px solid var(--green-light); border-radius: 6px;
      display: inline-block;
    }
    details.edit-user summary::-webkit-details-marker { display: none; }
    details.edit-user[open] summary { background: var(--green-light); }
    .edit-user-form {
      margin-top: 10px; padding: 12px 14px; background: #f0fdf4;
      border: 1px solid var(--green-light); border-radius: 8px;
      display: flex; flex-direction: column; gap: 8px;
    }
    .edit-user-form label { font-size: .75rem; font-weight: 700; color: var(--gray-500); }
    .edit-user-form input, .edit-user-form select {
      width: 100%; padding: 5px 8px; border: 1.5px solid var(--gray-200);
      border-radius: 6px; font-size: .82rem; background: #fff;
    }
    .edit-user-form .btn-save {
      padding: 5px 14px; font-size: .8rem; font-weight: 700;
      background: var(--green-mid); color: #fff;
      border: none; border-radius: 6px; cursor: pointer; align-self: flex-start;
    }
    .edit-user-form .btn-save:hover { background: var(--green-dark); }

    /* ── Sezione invita ───────────────────────────────────────────────── */
    .invite-section {
      border: 2px solid var(--green-light); border-radius: 12px;
      margin-bottom: 24px; overflow: hidden;
    }
    .invite-toggle {
      width: 100%; display: flex; align-items: center; justify-content: space-between;
      padding: 14px 20px; background: #f0fdf4; cursor: pointer;
      border: none; font-size: .9rem; font-weight: 700; color: var(--green-dark);
      text-align: left;
    }
    .invite-toggle .arrow { transition: transform .2s; font-size: .75rem; }
    .invite-body {
      padding: 20px 24px; background: #fff;
      display: none;
    }
    .invite-body.open { display: block; }
    .invite-grid { display: grid; grid-template-columns: 1fr 180px 180px auto; gap: 12px; align-items: end; }
    @media (max-width: 680px) {
      .invite-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <%- include('../partials/nav') %>
  <%- include('./_tabs') %>

  <div class="container">
    <div class="page-header">
      <h1>Gestione utenti</h1>
    </div>

    <%# ── Sezione Invita utente ──────────────────────────────────────────── %>
    <div class="invite-section" id="invita">
      <button class="invite-toggle" id="inviteToggle" type="button">
        <span>➕ Invita nuovo utente</span>
        <span class="arrow" id="inviteArrow">▼</span>
      </button>
      <div class="invite-body" id="inviteBody">
        <% if (inviteMessage) { %>
          <div class="alert alert-success" style="margin-bottom:16px;">✔ <%= inviteMessage %></div>
        <% } %>
        <% if (inviteError) { %>
          <div class="alert alert-error" style="margin-bottom:16px;">❌ <%= inviteError %></div>
        <% } %>
        <p style="font-size:.85rem; color:var(--gray-500); margin-bottom:16px;">
          L'utente verrà creato con la password predefinita <strong>primalogin2026</strong>
          e dovrà cambiarla al primo accesso.
        </p>
        <form action="/admin/users/invite" method="POST">
          <div class="invite-grid">
            <div>
              <label style="font-size:.78rem; font-weight:700; color:var(--gray-500); display:block; margin-bottom:4px;">Indirizzo email *</label>
              <input type="email" name="email" placeholder="utente@esempio.it" required
                     style="width:100%; padding:8px 12px; border:1.5px solid var(--gray-200); border-radius:7px; font-size:.9rem;">
            </div>
            <div>
              <label style="font-size:.78rem; font-weight:700; color:var(--gray-500); display:block; margin-bottom:4px;">Ruolo *</label>
              <select name="role" required
                      style="width:100%; padding:8px 10px; border:1.5px solid var(--gray-200); border-radius:7px; font-size:.9rem;">
                <option value="" disabled selected>Seleziona…</option>
                <option value="USER">User</option>
                <option value="POWER_USER">Power User</option>
                <option value="ADMIN">Admin</option>
              </select>
            </div>
            <div>
              <label style="font-size:.78rem; font-weight:700; color:var(--gray-500); display:block; margin-bottom:4px;">Email di benvenuto</label>
              <label style="display:flex; align-items:center; gap:8px; padding:8px 0; font-size:.88rem; cursor:pointer;">
                <input type="checkbox" name="sendEmail" value="1" checked
                       style="width:16px; height:16px; accent-color:var(--green-mid);">
                Invia email all'utente
              </label>
            </div>
            <div>
              <button type="submit" class="btn btn-primary" style="white-space:nowrap; padding:8px 20px;">
                Crea utente
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <% if (message) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>
    <% if (roleError === 'self') { %>
      <div class="alert alert-error">Non puoi modificare il tuo ruolo.</div>
    <% } %>
    <% if (roleError === 'invalid') { %>
      <div class="alert alert-error">Ruolo non valido.</div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (giocatoriIncompleti && giocatoriIncompleti.length > 0) { %>
    <div class="alert alert-info" style="border-color:#f59e0b; background:#fffbeb; color:#92400e;">
      <strong>⚠️ <%= giocatoriIncompleti.length %> giocator<%= giocatoriIncompleti.length === 1 ? 'e' : 'i' %> con dati incompleti:</strong>
      <ul style="margin:6px 0 0 16px; padding:0; font-size:.82rem;">
        <% giocatoriIncompleti.forEach(function(g) { %>
          <li>
            [<%= g.ruolo %>] <strong><%= g.nome %></strong>
            — squadra: <%= g.squadra || '<em>mancante</em>' %>
            · età: <%= g.eta != null ? g.eta : '<em>mancante</em>' %>
            · valore: <%= g.valore != null ? g.valore : '<em>mancante</em>' %>
            <a href="/fanta/lista-giocatori?search=<%= encodeURIComponent(g.nome) %>" style="margin-left:6px; color:#2563eb; font-size:.78rem;">✏️ Modifica</a>
          </li>
        <% }) %>
      </ul>
    </div>
    <% } %>

    <div class="user-grid">
      <% users.forEach(function(u) { %>
      <div class="user-card">
        <div class="user-card-header">
          <div class="user-card-email"><%= u.email %></div>
          <span class="badge <%= u.role === 'ADMIN' ? 'badge-admin' : u.role === 'POWER_USER' ? 'badge-poweruser' : 'badge-user' %>" style="flex-shrink:0;">
            <%= u.role === 'POWER_USER' ? 'Power User' : u.role %>
          </span>
        </div>

        <dl class="user-card-meta">
          <dt>Nickname</dt>
          <dd><%= u.nickname || '—' %></dd>
          <dt>FantaTeam</dt>
          <dd><% if (u.fantaTeam) { %><strong><%= u.fantaTeam.nome %></strong><% } else { %>—<% } %></dd>
          <dt>Stato</dt>
          <dd>
            <span class="badge <%= u.isActive ? 'badge-active' : 'badge-inactive' %>">
              <%= u.isActive ? 'Attivo' : 'Disabilitato' %>
            </span>
          </dd>
          <dt>Cambio pwd</dt>
          <dd style="color:<%= u.mustChangePassword ? '#b45309' : '#64748b' %>;"><%= u.mustChangePassword ? 'Richiesto' : 'No' %></dd>
          <dt>Creato il</dt>
          <dd><%= u.createdAt.toLocaleDateString('it-IT') %></dd>
        </dl>

        <div class="user-card-actions">
          <% if (u.id !== currentUser.id) { %>
          <form action="/admin/users/<%= u.id %>/reset-password" method="POST"
                onsubmit="return confirm('Reimpostare la password di <%= u.email %>?')">
            <button type="submit" class="btn btn-warning btn-sm">Reset pwd</button>
          </form>
          <form action="/admin/users/<%= u.id %>/change-role" method="POST" style="display:flex; gap:4px; align-items:center;">
            <select name="role" style="font-size:.8rem; padding:2px 6px; border-radius:4px; border:1px solid #cbd5e1;">
              <option value="USER"       <%= u.role === 'USER'       ? 'selected' : '' %>>User</option>
              <option value="POWER_USER" <%= u.role === 'POWER_USER' ? 'selected' : '' %>>Power User</option>
              <option value="ADMIN"      <%= u.role === 'ADMIN'      ? 'selected' : '' %>>Admin</option>
            </select>
            <button type="submit" class="btn btn-sm btn-primary">Salva</button>
          </form>
          <form action="/admin/users/<%= u.id %>/toggle" method="POST"
                onsubmit="return confirm('<%= u.isActive ? 'Disabilitare' : 'Abilitare' %> <%= u.email %>?')">
            <button type="submit" class="btn btn-sm <%= u.isActive ? 'btn-danger' : 'btn-success' %>">
              <%= u.isActive ? 'Disabilita' : 'Abilita' %>
            </button>
          </form>
          <form action="/admin/users/<%= u.id %>/delete" method="POST"
                onsubmit="return confirm('Sei sicuro di voler ELIMINARE definitivamente l\'utente <%= u.email %>?') && confirm('ATTENZIONE: questa operazione è irreversibile. Confermi?')">
            <button type="submit" class="btn btn-sm btn-danger">🗑️ Elimina</button>
          </form>
          <% if (u.isActive) { %>
          <form action="/admin/users/<%= u.id %>/impersonate" method="POST"
                onsubmit="return confirm('Impersonificare <%= u.email %>?\n\nVedrai il sistema come questo utente. Tutte le azioni saranno tracciate nei log con il tuo id admin.');">
            <button type="submit" class="btn btn-sm" style="background:#7d5a00; color:#fff;">🎭 Impersonifica</button>
          </form>
          <% } %>
          <% } else { %>
            <span style="font-size:.8rem; color:#94a3b8;">(tu)</span>
          <% } %>
        </div>

        <details class="edit-user">
          <summary>✏️ Modifica</summary>
          <form action="/admin/users/<%= u.id %>/save-fields" method="POST" class="edit-user-form">
            <div>
              <label>Email</label>
              <input type="email" name="email" value="<%= u.email %>" required>
            </div>
            <div>
              <label>Nickname</label>
              <input type="text" name="nickname" value="<%= u.nickname || '' %>" maxlength="40" placeholder="—">
            </div>
            <div>
              <label>FantaTeam</label>
              <select name="fantaTeamId">
                <option value="">— nessuno —</option>
                <% tuttiTeam.forEach(function(ft) { %>
                  <option value="<%= ft.id %>"
                    <%= u.fantaTeam && u.fantaTeam.id === ft.id ? 'selected' : '' %>
                    <%= ft.userId && ft.userId !== u.id ? 'style="color:#b91c1c;"' : '' %>>
                    <%= ft.nome %><%= ft.userId && ft.userId !== u.id ? ' (occupato)' : '' %>
                  </option>
                <% }) %>
              </select>
            </div>
            <button type="submit" class="btn-save">💾 Salva</button>
          </form>
        </details>
      </div>
      <% }); %>
    </div><!-- /user-grid -->

  </div><!-- /container -->

  <script>
    // ── Toggle sezione invita ──────────────────────────────────────────────────
    const toggle  = document.getElementById('inviteToggle');
    const body    = document.getElementById('inviteBody');
    const arrow   = document.getElementById('inviteArrow');

    function openInvite()  { body.classList.add('open');    arrow.style.transform = 'rotate(180deg)'; }
    function closeInvite() { body.classList.remove('open'); arrow.style.transform = ''; }

    toggle.addEventListener('click', () =>
      body.classList.contains('open') ? closeInvite() : openInvite()
    );

    // Auto-apri se ci sono messaggi di risposta all'invito o se l'anchor è #invita
    <% if (inviteMessage || inviteError) { %>
    openInvite();
    <% } %>
    if (window.location.hash === '#invita') openInvite();
  </script>
</body>
</html>
