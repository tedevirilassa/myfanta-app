<%/* views/partials/nav.ejs */%>
<style>
  .nav-dropdown { position:relative; }
  .nav-dropdown > .nav-dd-btn {
    background:none; border:none; cursor:pointer;
    color:inherit; font-size:inherit; padding:0;
    display:flex; align-items:center; gap:4px;
  }
  .nav-dd-menu {
    display:none; position:absolute; top:calc(100%+8px); left:0;
    background:#fff; border:1px solid var(--gray-200); border-radius:8px;
    box-shadow:0 8px 24px rgba(0,0,0,.12); min-width:160px; z-index:200;
    overflow:hidden;
  }
  .nav-dd-menu a {
    display:block; padding:9px 16px; font-size:.85rem;
    color:var(--green-dark); text-decoration:none; font-weight:600;
  }
  .nav-dd-menu a:hover { background:var(--gray-100); }
  .nav-dropdown:hover .nav-dd-menu { display:block; }

  /* ── HAMBURGER ── */
  .nav-hamburger {
    display:none; flex-direction:column; gap:5px;
    background:none; border:none; cursor:pointer; padding:4px;
  }
  .nav-hamburger span {
    display:block; width:24px; height:2px;
    background:var(--white); border-radius:2px;
    transition: transform .2s, opacity .2s;
  }

  /* ── MOBILE MENU ── */
  .nav-mobile {
    display:none; flex-direction:column;
    background:var(--green-dark);
    border-top:1px solid rgba(255,255,255,.1);
    padding:12px 0; z-index:99;
  }
  .nav-mobile.open { display:flex; }
  .nav-mobile a, .nav-mobile-section-title {
    display:block; padding:10px 24px; font-size:.9rem;
    color:#a7d7b8; text-decoration:none; font-weight:500;
  }
  .nav-mobile a:hover { background:rgba(255,255,255,.07); color:#fff; }
  .nav-mobile-section-title {
    font-size:.7rem; text-transform:uppercase; letter-spacing:.8px;
    color:rgba(255,255,255,.35); padding-top:16px; padding-bottom:4px;
  }
  .nav-mobile form { padding:8px 24px; }
  .nav-mobile form button {
    width:100%; background:rgba(255,255,255,.08);
    border:1px solid rgba(255,255,255,.2); color:#a7d7b8;
    padding:9px 14px; border-radius:6px; cursor:pointer;
    font-size:.88rem; font-weight:500;
  }

  @media (max-width: 1024px) {
    .nav-right { display:none !important; }
    .nav-hamburger { display:flex; }
  }
</style>
<nav>
  <span class="brand">MyFanta</span>
  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
  <div class="nav-right">
    <div class="nav-dropdown">
      <button class="nav-dd-btn">
        👤 <%= currentUser.nickname || currentUser.email.split('@')[0] %> ▾
      </button>
      <div class="nav-dd-menu" style="right:0;left:auto;">
        <a href="/profilo">✏️ Il mio profilo</a>
        <a href="/auth/change-password">🔑 Cambia password</a>
      </div>
    </div>
    <span class="badge <%= currentUser.role === 'ADMIN' ? 'badge-admin' : 'badge-user' %>"><%= currentUser.role %></span>
    <a href="/fanta/classifica">💰 Situazione Patrimoniale</a>
    <a href="/fanta/rose">📋 Rose</a>
    <a href="/fanta/regolamento">📖 Regolamento</a>
    <% if (currentUser.role === 'ADMIN') { %>
    <div class="nav-dropdown">
      <button class="nav-dd-btn">📊 Fogli ▾</button>
      <div class="nav-dd-menu">
        <a href="/fanta/riepilogo">📊 Riepilogo</a>
        <a href="/fanta/giocatori">⚽ Giocatori</a>
        <a href="/fanta/finanze">💰 Finanze</a>
        <a href="/fanta/diario">📖 Diario</a>
        <a href="/fanta/log">📝 Log</a>
      </div>
    </div>
    <% } %>
    <a href="/fanta/lista-giocatori">📋 Lista Giocatori</a>
    <% if (currentUser.role === 'ADMIN') { %>
      <a href="/admin/contratti/riepilogo">📋 Riepilogo Contratti</a>
      <div class="nav-dropdown">
        <button class="nav-dd-btn">⚙️ Admin ▾</button>
        <div class="nav-dd-menu">
          <a href="/admin/contratti/nuovo">📝 Nuovo Contratto</a>
          <a href="/admin/sync-transfermarkt">📈 Sync Transfermarkt</a>
          <a href="/admin/users">👥 Gestione Utenti</a>
          <a href="/admin/users/invite">➕ Invita Utente</a>
          <a href="/admin/situazione-finanziaria">💰 Situazione Finanziaria</a>
          <a href="/admin/rosa">📋 Gestione Rose</a>
          <a href="/admin/parametri">⚙️ Parametri</a>
          <a href="/admin/log">📝 Log Azioni</a>
        </div>
      </div>
    <% } %>
    <form action="/auth/logout" method="POST">
      <button type="submit">Esci</button>
    </form>
  </div>

  <!-- Hamburger button (mobile) -->
  <button class="nav-hamburger" id="nav-hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
  <% } %>
</nav>

<% if (typeof currentUser !== 'undefined' && currentUser) { %>
<div class="nav-mobile" id="nav-mobile">
  <span class="nav-mobile-section-title">👤 <%= currentUser.nickname || currentUser.email.split('@')[0] %></span>
  <a href="/profilo">✏️ Il mio profilo</a>
  <a href="/auth/change-password">🔑 Cambia password</a>
  <span class="nav-mobile-section-title">Navigazione</span>
  <a href="/fanta/classifica">💰 Situazione Patrimoniale</a>
  <a href="/fanta/rose">📋 Rose</a>
  <a href="/fanta/riepilogo">📊 Riepilogo</a>
  <a href="/fanta/giocatori">⚽ Giocatori</a>
  <a href="/fanta/finanze">💰 Finanze</a>
  <a href="/fanta/diario">📖 Diario</a>
  <a href="/fanta/log">📝 Log</a>
  <a href="/fanta/lista-giocatori">📋 Lista Giocatori</a>
  <% if (currentUser.role === 'ADMIN') { %>
  <a href="/admin/contratti/riepilogo">📋 Riepilogo Contratti</a>
  <span class="nav-mobile-section-title">⚙️ Admin</span>
  <a href="/admin/contratti/nuovo">📝 Nuovo Contratto</a>
  <a href="/admin/sync-transfermarkt">📈 Sync Transfermarkt</a>
  <a href="/admin/users">👥 Gestione Utenti</a>
  <a href="/admin/users/invite">➕ Invita Utente</a>
  <a href="/admin/situazione-finanziaria">💰 Situazione Finanziaria</a>
  <a href="/admin/rosa">📋 Gestione Rose</a>
  <a href="/admin/parametri">⚙️ Parametri</a>
  <a href="/admin/log">📝 Log Azioni</a>
  <% } %>
  <form action="/auth/logout" method="POST" style="margin-top:8px;">
    <button type="submit">🚪 Esci</button>
  </form>
</div>
<script>
  document.getElementById('nav-hamburger').addEventListener('click', function() {
    document.getElementById('nav-mobile').classList.toggle('open');
  });
</script>
<% } %>
