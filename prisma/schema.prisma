generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int        @id @default(autoincrement())
  email              String     @unique
  passwordHash       String
  role               Role       @default(USER)
  isActive           Boolean    @default(true)
  mustChangePassword Boolean    @default(true)
  invitedById        Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  nickname           String?
  fantaTeam          FantaTeam?
  invitedBy          User?      @relation("UserInvites", fields: [invitedById], references: [id])
  invitees           User[]     @relation("UserInvites")
  logs               Log[]

  @@map("fantapresidenti")
}

model FantaTeam {
  id                    Int                      @id @default(autoincrement())
  nome                  String
  userId                Int?                     @unique
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @default(now()) @updatedAt
  contratti             Contratto[]
  user                  User?                    @relation(fields: [userId], references: [id])
  situazioniFinanziarie SituazioneFinanziaria[]
  rosaGiocatori         RosaGiocatore[]
  propostaRinnovi       PropostaRinnovo[]
  trattativeMittente    TrattativaMercato[]      @relation("TrattativeMittente")
  trattativeRicevente   TrattativaMercato[]      @relation("TrattativeRicevente")

  @@map("fanta_teams")
}

model SituazioneFinanziaria {
  id                 Int        @id @default(autoincrement())
  nomePresidente     String
  stagione           String     // es. "2025-2026"
  valoreRose         Decimal    @db.Decimal(10, 2)
  crediti            Decimal    @db.Decimal(10, 2)
  patrimonio         Decimal    @db.Decimal(10, 2)
  giocatoriTesserati Int
  etaMedia           Decimal    @db.Decimal(5, 2)
  stipendi           Decimal    @db.Decimal(10, 2)
  montePrestiti      Decimal    @db.Decimal(10, 2)
  ultimoPlusMinus    Decimal    @db.Decimal(10, 2)
  fantaTeamId        Int?
  fantaTeam          FantaTeam? @relation(fields: [fantaTeamId], references: [id])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @default(now()) @updatedAt

  @@unique([nomePresidente, stagione])
  @@unique([fantaTeamId, stagione])
  @@map("situazione_finanziaria")
}

model Giocatore {
  id              Int         @id @default(autoincrement())
  nome            String
  ruoloEsteso     String?
  ruolo           String      @db.Char(1)
  squadra         String?
  eta             Int?
  anniContratto   Int?
  valore          Decimal?    @db.Decimal(10, 2)
  dataNascita     String?
  nazionalita     String?
  transfermarktId String?     @unique
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  contratti       Contratto[]
  rosaGiocatori   RosaGiocatore[]
  quotazioni      Quotazione[]
  propostaRinnovi PropostaRinnovo[]
  trattative      TrattativaMercato[]

  @@map("giocatori")
}

model Quotazione {
  id          Int       @id @default(autoincrement())
  giocatoreId Int
  valore      Decimal?  @db.Decimal(10, 2)
  fonte       String?   @default("transfermarkt")
  stagione    String?
  createdAt   DateTime  @default(now())
  giocatore   Giocatore @relation(fields: [giocatoreId], references: [id])

  @@map("quotazioni")
}

model Contratto {
  id                Int                   @id @default(autoincrement())
  tipo              TipoContratto
  clausola          ClausolaContratto?
  dataStipula       String
  durataContratto   Int
  dataFine          String?
  giocatoreId       Int
  valoreGiocatore   Decimal?              @db.Decimal(10, 2)
  importoOperazione Decimal?              @db.Decimal(10, 2)
  prezzoAcquisto    Decimal?              @db.Decimal(10, 2)
  provenienza       String?
  destinazione      String
  valido            Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  fantaTeamId       Int
  fantaTeam         FantaTeam             @relation(fields: [fantaTeamId], references: [id])
  giocatore         Giocatore             @relation(fields: [giocatoreId], references: [id])
  propostaRinnovo   PropostaRinnovo?

  @@map("contratti")
}

enum Role {
  ADMIN
  USER
  POWER_USER
}

enum TipoContratto {
  Acquisto
  Cessione
  Prestito
}

enum ClausolaContratto {
  DirittoRiscatto
  DirittoRicompra
  ObbligoRiscatto
  ObbligoRicompra
}

enum TipoPremio {
  InizioStagione
  Gennaio
  Classifica
}

model PremioErogato {
  id          Int        @id @default(autoincrement())
  tipo        TipoPremio
  stagione    String?    // opzionale, dedotta a posteriori dalla data
  totale      Decimal    @db.Decimal(10, 2)
  numBenef    Int        // numero presidenti che hanno ricevuto qualcosa
  createdAt   DateTime   @default(now())
  adminId     Int

  @@map("premi_erogati")
}

model Log {
  id         Int      @id @default(autoincrement())
  azione     String              // CREATE | UPDATE | DELETE
  entita     String              // contratto | utente | giocatore | ...
  entitaId   Int?                // id dell'oggetto coinvolto
  dettaglio  String?  @db.Text  // JSON con i campi modificati
  rollbacked Boolean  @default(false) // true se questa azione è stata annullata
  adminId    Int
  admin      User     @relation(fields: [adminId], references: [id])
  createdAt  DateTime @default(now())

  @@map("log_azioni")
}

model Parametro {
  id          Int      @id @default(autoincrement())
  chiave      String   @unique
  valore      String
  descrizione String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("parametri")
}

enum CategoriaRosa {
  InRosa
  FuoriRosa
  U21
}

model RosaGiocatore {
  id           Int            @id @default(autoincrement())
  fantaTeamId  Int
  giocatoreId  Int
  stagione     String         // es. "2025-2026"
  categoria    CategoriaRosa  @default(InRosa)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now()) @updatedAt
  fantaTeam    FantaTeam      @relation(fields: [fantaTeamId], references: [id])
  giocatore    Giocatore      @relation(fields: [giocatoreId], references: [id])

  @@unique([fantaTeamId, giocatoreId, stagione])
  @@map("rosa_giocatori")
}

enum StatoTrattativa {
  PENDING            // offerta inviata, attende risposta
  ACCEPTED           // accettata, attende finalizzazione
  REJECTED           // rifiutata
  COMPLETED          // trasferimento completato (immediato)
  COMPLETED_DEFERRED // trasferimento finalizzato con decorrenza futura (in attesa di attivazione)
  EXPIRED            // scaduta senza risposta
}

model TrattativaMercato {
  id                   Int              @id @default(autoincrement())
  giocatoreId          Int
  fantaTeamMittenteId  Int
  fantaTeamRiceventeId Int
  importoOfferta       Decimal          @db.Decimal(10, 2)
  valoreRiferimento    Decimal          @db.Decimal(10, 2)  // valore TM al momento dell'offerta
  stato                StatoTrattativa  @default(PENDING)
  motivoRifiuto        String?
  dataDecorrenza       String?          // MM-YYYY: mese di decorrenza effettiva dell'operazione
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  scadenzaAt           DateTime?        // opzionale: data entro cui rispondere
  contrattoNuovoId     Int?             // popolato alla finalizzazione
  giocatore            Giocatore        @relation(fields: [giocatoreId], references: [id])
  fantaTeamMittente    FantaTeam        @relation("TrattativeMittente",  fields: [fantaTeamMittenteId],  references: [id])
  fantaTeamRicevente   FantaTeam        @relation("TrattativeRicevente", fields: [fantaTeamRiceventeId], references: [id])

  @@map("trattative_mercato")
}

enum StatoRinnovo {
  PENDING
  APPROVED
  REJECTED
}

model PropostaRinnovo {
  id              Int          @id @default(autoincrement())
  contrattoId     Int          @unique
  fantaTeamId     Int
  giocatoreId     Int
  stagione        String       // stagione di destinazione del rinnovo (es. "2026-2027")
  nuovaDurata     Int          // anni (1..3 secondo parametri)
  nuovoIngaggio   Decimal      @db.Decimal(10, 2)
  ordinePriorita  Int          // 1 = priorità massima
  status          StatoRinnovo @default(PENDING)
  motivoStato     String?      // testo motivazione popolato alla finalize (per APPROVED/REJECTED)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  contratto       Contratto    @relation(fields: [contrattoId], references: [id])
  fantaTeam       FantaTeam    @relation(fields: [fantaTeamId], references: [id])
  giocatore       Giocatore    @relation(fields: [giocatoreId], references: [id])

  @@unique([fantaTeamId, stagione, ordinePriorita])
  @@index([fantaTeamId, ordinePriorita])
  @@map("proposte_rinnovo")
}
