{
  "name": "myfanta-app",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "prisma generate && PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install --with-deps chromium",
    "postinstall": "prisma generate && PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "prod:migrate": "node scripts/sync-to-prod.js --migrate-only",
    "prod:sync": "node scripts/sync-to-prod.js",
    "prod:migrate-and-sync": "node scripts/sync-to-prod.js --migrate",
    "prod:restart": "node scripts/restart-prod.js",
    "prod:upload-env": "node scripts/prod-upload-env.js",
    "prod:deploy": "node scripts/deploy-to-prod.js --no-install",
    "prod:deploy-install": "node scripts/deploy-to-prod.js",
    "prod:deploy-dry": "node scripts/deploy-to-prod.js --dry-run",
    "db:backup": "node scripts/backup-db.js",
    "db:backup-remote": "node scripts/backup-db.js --remote",
    "db:restore": "node scripts/restore-db.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "prisma": "^7.8.0",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "ssh2": "^1.17.0"
  }
}
